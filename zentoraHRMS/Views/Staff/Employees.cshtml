@model IEnumerable<zentoraHRMS.Models.EmployeeModel>
@{
    ViewBag.Title = "Employee Directory";
}

<style>
    /* Styling for Choices.js validation error state */
    select.is-invalid + .choices .choices__inner {
        border-color: #dc3545 !important;
    }
    .choices.is-invalid .choices__inner {
        border-color: #dc3545 !important;
    }
    /* Ensure invalid feedback shows up for selects with Choices.js */
    select.is-invalid ~ .invalid-feedback {
        display: block !important;
    }
</style>

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">Employee Directory</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title">Employee Details</h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" data-bs-toggle="modal" data-bs-target="#AddEmpModal">
                        <i class="me-1" data-lucide="plus"></i> Add Employee
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Emp Code</th>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>Designation</th>
                                <th>Department</th>
                                <th>Sub-Department</th>
                                <th>Branch</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td>@c.EmpCode</td>
                                    <td>@c.FirstName @c.LastName</td>
                                    <td>@c.Phone</td>
                                    <td>@c.Email</td>
                                    <td>@c.Designation</td>
                                    <td>@c.Department</td>
                                    <td>@c.SubDepartment</td>
                                    <td>@c.Branch</td>
                                    <td>
                                        @if (c.IsActive) { <span class="badge bg-success-subtle text-success">Active</span> }
                                        else { <span class="badge bg-danger-subtle text-danger">Inactive</span> }
                                    </td>
                                    <td>
                                        <a onclick="UpdateEmp(@c.Id)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeleteEmp(@c.Id)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddEmp Modal -->
    <div id="AddEmpModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <form id="EmpForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Add New Employee</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="EmpCode" class="form-label">Employee Code <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="EmpCode" required>
                                <div class="invalid-feedback">Please enter the Employee Code.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="Username" class="form-label">Username <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="Username" required>
                                <div class="invalid-feedback">Please enter the Username.</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="FirstName" class="form-label">First Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="FirstName" required>
                                <div class="invalid-feedback">Please enter the First Name.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="LastName" class="form-label">LastName <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="LastName" required>
                                <div class="invalid-feedback">Please enter the Last Name.</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="Phone" class="form-label">Phone <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="Phone" required>
                                <div class="invalid-feedback">Please enter the Phone number.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" id="Email" required>
                                <div class="invalid-feedback">Please enter a valid Email address.</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="Designation" class="form-label">Designation <span class="text-danger">*</span></label>
                                <select class="form-control form-select" id="Designation" data-choices required>
                                    <option value="">Loading...</option>
                                </select>
                                <div class="invalid-feedback">Please select the Designation.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="Department" class="form-label">Department <span class="text-danger">*</span></label>
                                <select class="form-control form-select" id="Department" data-choices required>
                                    <option value="">Loading...</option>
                                </select>
                                <div class="invalid-feedback">Please select the Department.</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="SubDepartment" class="form-label">Sub-Department <span class="text-danger">*</span></label>
                                <select class="form-control form-select" id="SubDepartment" data-choices required>
                                    <option value="">Loading...</option>
                                </select>
                                <div class="invalid-feedback">Please select the Sub-Department.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="Branch" class="form-label">Branch <span class="text-danger">*</span></label>
                                <select class="form-control form-select" id="Branch" data-choices required>
                                    <option value="">Loading...</option>
                                </select>
                                <div class="invalid-feedback">Please select the Branch.</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="Company" class="form-label">Company <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="Company" placeholder="e.g. Zentora Corporate" required>
                                <div class="invalid-feedback">Please enter the Company.</div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- UpdateEmp Modal -->
    <div id="UpdateEmpModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <form id="UpdateEmpForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Update Employee Details</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="update_id" />
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="uEmpCode" class="form-label">Employee Code <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="uEmpCode" required>
                                <div class="invalid-feedback">Please enter the Employee Code.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="uUsername" class="form-label">Username <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="uUsername" required>
                                <div class="invalid-feedback">Please enter the Username.</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="uFirstName" class="form-label">First Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="uFirstName" required>
                                <div class="invalid-feedback">Please enter the First Name.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="uLastName" class="form-label">LastName <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="uLastName" required>
                                <div class="invalid-feedback">Please enter the Last Name.</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="uPhone" class="form-label">Phone <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="uPhone" required>
                                <div class="invalid-feedback">Please enter the Phone number.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="uEmail" class="form-label">Email <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" id="uEmail" required>
                                <div class="invalid-feedback">Please enter a valid Email address.</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="uDesignation" class="form-label">Designation <span class="text-danger">*</span></label>
                                <select class="form-control form-select" id="uDesignation" data-choices required>
                                    <option value="">Loading...</option>
                                </select>
                                <div class="invalid-feedback">Please select the Designation.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="uDepartment" class="form-label">Department <span class="text-danger">*</span></label>
                                <select class="form-control form-select" id="uDepartment" data-choices required>
                                    <option value="">Loading...</option>
                                </select>
                                <div class="invalid-feedback">Please select the Department.</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="uSubDepartment" class="form-label">Sub-Department <span class="text-danger">*</span></label>
                                <select class="form-control form-select" id="uSubDepartment" data-choices required>
                                    <option value="">Loading...</option>
                                </select>
                                <div class="invalid-feedback">Please select the Sub-Department.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="uBranch" class="form-label">Branch <span class="text-danger">*</span></label>
                                <select class="form-control form-select" id="uBranch" data-choices required>
                                    <option value="">Loading...</option>
                                </select>
                                <div class="invalid-feedback">Please select the Branch.</div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="uCompany" class="form-label">Company <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="uCompany" required>
                                <div class="invalid-feedback">Please enter the Company.</div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Intercept data-choices elements before DOMContentLoaded to prevent automatic double initialization
    document.querySelectorAll('#Designation, #uDesignation, #Department, #uDepartment, #SubDepartment, #uSubDepartment, #Branch, #uBranch').forEach(function(el) {
        el.removeAttribute('data-choices');
    });

    var designationChoice, departmentChoice, subdepartmentChoice, branchChoice;
    var uDesignationChoice, uDepartmentChoice, uSubdepartmentChoice, uBranchChoice;

    $(document).ready(function () {
        // Initialize Choices instances manually
        initChoices();

        // Load initial dropdowns (Designations and Branches)
        loadInitialDropdowns();

        // Branch changes cascade
        $('#Branch').on('change', function () {
            var branchName = $(this).val();
            if (branchName) {
                $.ajax({
                    url: '/Staff/GetDepartmentsByBranch',
                    type: 'GET',
                    data: { branchName: branchName },
                    success: function (list) {
                        setSelectChoices(departmentChoice, list, 'Select Department', true);
                        setSelectChoices(subdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
                    }
                });
            } else {
                setSelectChoices(departmentChoice, [], 'Select Department (Please select Branch first)', false);
                setSelectChoices(subdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
            }
        });

        $('#uBranch').on('change', function () {
            var branchName = $(this).val();
            if (branchName) {
                $.ajax({
                    url: '/Staff/GetDepartmentsByBranch',
                    type: 'GET',
                    data: { branchName: branchName },
                    success: function (list) {
                        setSelectChoices(uDepartmentChoice, list, 'Select Department', true);
                        setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
                    }
                });
            } else {
                setSelectChoices(uDepartmentChoice, [], 'Select Department (Please select Branch first)', false);
                setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
            }
        });

        // Department changes cascade
        $('#Department').on('change', function () {
            var departmentName = $(this).val();
            if (departmentName) {
                $.ajax({
                    url: '/Staff/GetSubDepartmentsByDepartment',
                    type: 'GET',
                    data: { departmentName: departmentName },
                    success: function (list) {
                        setSelectChoices(subdepartmentChoice, list, 'Select Sub-Department', true);
                    }
                });
            } else {
                setSelectChoices(subdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
            }
        });

        $('#uDepartment').on('change', function () {
            var departmentName = $(this).val();
            if (departmentName) {
                $.ajax({
                    url: '/Staff/GetSubDepartmentsByDepartment',
                    type: 'GET',
                    data: { departmentName: departmentName },
                    success: function (list) {
                        setSelectChoices(uSubdepartmentChoice, list, 'Select Sub-Department', true);
                    }
                });
            } else {
                setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
            }
        });

        $("#EmpForm").on("submit", function (e) {
            e.preventDefault();
            if (!validateForm('EmpForm')) {
                return false;
            }
            var formData = {
                EmpCode: $("#EmpCode").val(),
                Username: $("#Username").val(),
                FirstName: $("#FirstName").val(),
                LastName: $("#LastName").val(),
                Phone: $("#Phone").val(),
                Email: $("#Email").val(),
                Designation: $("#Designation").val(),
                Department: $("#Department").val(),
                SubDepartment: $("#SubDepartment").val(),
                Company: $("#Company").val(),
                Branch: $("#Branch").val()
            };
            $.ajax({
                url: '/Staff/SaveEmployee',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        $("#UpdateEmpForm").on("submit", function (e) {
            e.preventDefault();
            if (!validateForm('UpdateEmpForm')) {
                return false;
            }
            var formData = {
                Id: $("#update_id").val(),
                EmpCode: $("#uEmpCode").val(),
                Username: $("#uUsername").val(),
                FirstName: $("#uFirstName").val(),
                LastName: $("#uLastName").val(),
                Phone: $("#uPhone").val(),
                Email: $("#uEmail").val(),
                Designation: $("#uDesignation").val(),
                Department: $("#uDepartment").val(),
                SubDepartment: $("#uSubDepartment").val(),
                Company: $("#uCompany").val(),
                Branch: $("#uBranch").val()
            };
            $.ajax({
                url: '/Staff/UpdateEmployee',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });
    });

    function initChoices() {
        designationChoice = new Choices('#Designation', { searchEnabled: true, shouldSort: false });
        departmentChoice = new Choices('#Department', { searchEnabled: true, shouldSort: false });
        subdepartmentChoice = new Choices('#SubDepartment', { searchEnabled: true, shouldSort: false });
        branchChoice = new Choices('#Branch', { searchEnabled: true, shouldSort: false });

        uDesignationChoice = new Choices('#uDesignation', { searchEnabled: true, shouldSort: false });
        uDepartmentChoice = new Choices('#uDepartment', { searchEnabled: true, shouldSort: false });
        uSubdepartmentChoice = new Choices('#uSubDepartment', { searchEnabled: true, shouldSort: false });
        uBranchChoice = new Choices('#uBranch', { searchEnabled: true, shouldSort: false });
    }

    function setSelectChoices(choiceInstance, list, placeholderText, enabled) {
        choiceInstance.clearStore();
        
        var choicesArray = [];
        if (placeholderText) {
            choicesArray.push({
                value: '',
                label: placeholderText,
                selected: true,
                disabled: true
            });
        }
        
        $.each(list, function (i, item) {
            choicesArray.push({
                value: item,
                label: item,
                selected: false,
                disabled: false
            });
        });
        
        choiceInstance.setChoices(choicesArray, 'value', 'label', true);
        if (enabled) {
            choiceInstance.enable();
        } else {
            choiceInstance.disable();
        }
    }

    function loadInitialDropdowns() {
        $.ajax({
            url: '/Staff/GetDesignationsList',
            type: 'GET',
            success: function (list) {
                setSelectChoices(designationChoice, list, 'Select Designation', true);
                setSelectChoices(uDesignationChoice, list, 'Select Designation', true);
            }
        });

        $.ajax({
            url: '/Staff/GetBranchesList',
            type: 'GET',
            success: function (list) {
                setSelectChoices(branchChoice, list, 'Select Branch', true);
                setSelectChoices(uBranchChoice, list, 'Select Branch', true);
            }
        });
        
        // Initially disable Department and SubDepartment
        setSelectChoices(departmentChoice, [], 'Select Department (Please select Branch first)', false);
        setSelectChoices(uDepartmentChoice, [], 'Select Department (Please select Branch first)', false);
        setSelectChoices(subdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
        setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
    }

    function validateForm(formId) {
        var isValid = true;
        
        // Remove all previous validation styling
        $('#' + formId + ' .is-invalid').removeClass('is-invalid');
        $('#' + formId + ' .choices').removeClass('is-invalid');
        
        var isUpdate = (formId === 'UpdateEmpForm');
        var prefix = isUpdate ? 'u' : '';
        
        var fields = [
            { id: prefix + 'EmpCode', name: 'Employee Code', isSelect: false },
            { id: prefix + 'Username', name: 'Username', isSelect: false },
            { id: prefix + 'FirstName', name: 'First Name', isSelect: false },
            { id: prefix + 'LastName', name: 'Last Name', isSelect: false },
            { id: prefix + 'Phone', name: 'Phone', isSelect: false },
            { id: prefix + 'Email', name: 'Email', isSelect: false },
            { id: prefix + 'Designation', name: 'Designation', isSelect: true },
            { id: prefix + 'Department', name: 'Department', isSelect: true },
            { id: prefix + 'SubDepartment', name: 'Sub-Department', isSelect: true },
            { id: prefix + 'Branch', name: 'Branch', isSelect: true },
            { id: prefix + 'Company', name: 'Company', isSelect: false }
        ];
        
        $.each(fields, function (i, field) {
            var $el = $('#' + field.id);
            var val = $el.val();
            
            if (!val || val.trim() === '') {
                isValid = false;
                $el.addClass('is-invalid');
                
                var $container = field.isSelect ? $el.closest('.choices') : $el;
                if (field.isSelect) {
                    $container.addClass('is-invalid');
                }
                
                var $feedback = $container.siblings('.invalid-feedback');
                var msg = field.isSelect ? 'Please select the ' + field.name + '.' : 'Please enter the ' + field.name + '.';
                if ($feedback.length === 0) {
                    $container.parent().append('<div class="invalid-feedback">' + msg + '</div>');
                } else {
                    $feedback.text(msg);
                }
            }
        });
        
        return isValid;
    }

    function UpdateEmp(id) {
        $.ajax({
            url: '/Staff/GetEmployeeById',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                if (data) {
                    $("#update_id").val(data.Id);
                    $("#uEmpCode").val(data.EmpCode);
                    $("#uUsername").val(data.Username);
                    $("#uFirstName").val(data.FirstName);
                    $("#uLastName").val(data.LastName);
                    $("#uPhone").val(data.Phone);
                    $("#uEmail").val(data.Email);
                    $("#uCompany").val(data.Company);
                    
                    // Trigger Cascades sequentially
                    uDesignationChoice.setChoiceByValue(data.Designation);
                    uBranchChoice.setChoiceByValue(data.Branch);
                    
                    if (data.Branch) {
                        $.ajax({
                            url: '/Staff/GetDepartmentsByBranch',
                            type: 'GET',
                            data: { branchName: data.Branch },
                            success: function (deptList) {
                                setSelectChoices(uDepartmentChoice, deptList, 'Select Department', true);
                                uDepartmentChoice.setChoiceByValue(data.Department);
                                
                                if (data.Department) {
                                    $.ajax({
                                        url: '/Staff/GetSubDepartmentsByDepartment',
                                        type: 'GET',
                                        data: { departmentName: data.Department },
                                        success: function (subDeptList) {
                                            setSelectChoices(uSubdepartmentChoice, subDeptList, 'Select Sub-Department', true);
                                            uSubdepartmentChoice.setChoiceByValue(data.SubDepartment);
                                            $("#UpdateEmpModal").modal("show");
                                        }
                                    });
                                } else {
                                    setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
                                    $("#UpdateEmpModal").modal("show");
                                }
                            }
                        });
                    } else {
                        setSelectChoices(uDepartmentChoice, [], 'Select Department (Please select Branch first)', false);
                        setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
                        $("#UpdateEmpModal").modal("show");
                    }
                }
            }
        });
    }

    function DeleteEmp(id) {
        if (confirm("Are you sure you want to delete this employee?")) {
            $.ajax({
                url: '/Staff/DeleteEmployee',
                type: "POST",
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        }
    }
</script>
