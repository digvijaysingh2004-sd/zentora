@model IEnumerable<zentoraHRMS.Models.EmployeeModel>
@{
    ViewBag.Title = "Employee Directory";
}

<style>
    /* Styling for Choices.js validation error state */
    select.is-invalid + .choices .choices__inner {
        border-color: #dc3545 !important;
    }
    .choices.is-invalid .choices__inner {
        border-color: #dc3545 !important;
    }
    /* Ensure invalid feedback shows up for selects with Choices.js */
    select.is-invalid ~ .invalid-feedback {
        display: block !important;
    }
    /* Smooth transitions for tabs */
    .tab-pane {
        animation: fadeIn 0.3s ease-in-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">Employee Directory</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title">Employee Details</h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" onclick="OpenAddModal()">
                        <i class="me-1" data-lucide="plus"></i> Add Employee
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Emp Code</th>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Designation</th>
                                <th>Department</th>
                                <th>Branch</th>
                                <th>Shift</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td class="fw-semibold">@c.EmpCode</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(c.ProfileImage))
                                            {
                                                <img src="@c.ProfileImage" class="rounded-circle border border-2 border-light-subtle shadow-sm" alt="Profile" style="width: 38px; height: 38px; object-fit: cover;" onerror="this.onerror=null; this.src='/assets/images/users/avatar-1.jpg';" />
                                            }
                                            else
                                            {
                                                <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center shadow-sm fw-semibold" style="width: 38px; height: 38px; font-size: 11px; min-width: 38px;">
                                                    @(c.FirstName.Length > 0 ? c.FirstName.Substring(0,1) : "")@(c.LastName.Length > 0 ? c.LastName.Substring(0,1) : "")
                                                </div>
                                            }
                                            <div>
                                                <h6 class="mb-0 fs-sm fw-semibold">@c.FirstName @(string.IsNullOrEmpty(c.MiddleName) ? "" : c.MiddleName + " ") @c.LastName</h6>
                                                <span class="text-muted fs-xxs">@c.Email</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@(c.PhoneCode ?? "+91") @c.Phone</td>
                                    <td>@c.Designation</td>
                                    <td>@c.Department</td>
                                    <td>@c.Branch</td>
                                    <td>@(string.IsNullOrEmpty(c.OfficeShift) ? "General" : c.OfficeShift)</td>
                                    <td>
                                        @if (c.IsActive) { <span class="badge bg-success-subtle text-success">Active</span> }
                                        else { <span class="badge bg-danger-subtle text-danger">Inactive</span> }
                                    </td>
                                    <td>
                                        <a onclick="UpdateEmp(@c.Id)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeleteEmp(@c.Id)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddEmp Modal -->
    <div id="AddEmpModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <form id="EmpForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header border-bottom-0 pb-0">
                        <h4 class="modal-title fw-bold">Add New Employee</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <!-- Navigation Tabs -->
                        <ul class="nav nav-pills nav-justified bg-light rounded-pill p-1 mb-4" role="tablist">
                            <li class="nav-item">
                                <button class="nav-link rounded-pill active py-2" data-bs-toggle="tab" data-bs-target="#add-personal" type="button" role="tab">Personal</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link rounded-pill py-2" data-bs-toggle="tab" data-bs-target="#add-contact" type="button" role="tab">Contact</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link rounded-pill py-2" data-bs-toggle="tab" data-bs-target="#add-job" type="button" role="tab">Job & Work</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link rounded-pill py-2" data-bs-toggle="tab" data-bs-target="#add-relations" type="button" role="tab">Relations</button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <!-- Personal Tab -->
                            <div class="tab-pane fade show active" id="add-personal" role="tabpanel">
                                <!-- Profile Photo Upload Section -->
                                <div class="row align-items-center mb-4 bg-light-subtle p-3 rounded border border-dashed">
                                    <div class="col-auto">
                                        <div class="position-relative d-inline-block">
                                            <img id="avatar-preview" src="/assets/images/users/avatar-1.jpg" class="rounded-circle border border-3 border-light shadow-sm" style="width: 80px; height: 80px; object-fit: cover;" onerror="this.onerror=null; this.src='/assets/images/users/avatar-1.jpg';" />
                                            <span id="upload-spinner" class="spinner-border spinner-border-sm text-primary position-absolute top-50 start-50 translate-middle d-none" role="status"></span>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <h6 class="fw-bold mb-1 text-heading">Profile Photo</h6>
                                        <p class="text-muted fs-xxs mb-2">Upload a picture from your device or specify a web URL.</p>
                                        <div class="d-flex gap-2">
                                            <button type="button" class="btn btn-sm btn-soft-primary" onclick="triggerFileUpload('add')">
                                                <i class="me-1" data-lucide="upload-cloud"></i> Upload File
                                            </button>
                                            <button type="button" class="btn btn-sm btn-soft-secondary" onclick="toggleUrlInput('add')">
                                                <i class="me-1" data-lucide="link-2"></i> Use URL
                                            </button>
                                        </div>
                                        <input type="file" id="file-upload-add" class="d-none" accept="image/*" onchange="handleFileChange(this, 'add')">
                                        <div id="url-input-container-add" class="mt-2 d-none" style="max-width: 400px;">
                                            <input type="url" class="form-control form-control-sm" id="ProfileImage" placeholder="Paste image URL here..." oninput="handleUrlInput(this, 'add')">
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label for="FirstName" class="form-label fw-semibold">First Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="FirstName" required>
                                        <div class="invalid-feedback">First Name is required.</div>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="MiddleName" class="form-label fw-semibold">Middle Name</label>
                                        <input type="text" class="form-control" id="MiddleName">
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="LastName" class="form-label fw-semibold">Last Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="LastName" required>
                                        <div class="invalid-feedback">Last Name is required.</div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label for="Gender" class="form-label fw-semibold">Gender</label>
                                        <select class="form-select form-control" id="Gender">
                                            <option value="">Select Gender</option>
                                            <option value="Male">Male</option>
                                            <option value="Female">Female</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="MaritalStatus" class="form-label fw-semibold">Marital Status</label>
                                        <select class="form-select form-control" id="MaritalStatus">
                                            <option value="">Select Status</option>
                                            <option value="Single">Single</option>
                                            <option value="Married">Married</option>
                                            <option value="Divorced">Divorced</option>
                                            <option value="Widowed">Widowed</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="DOB" class="form-label fw-semibold">Date of Birth</label>
                                        <input type="date" class="form-control" id="DOB">
                                    </div>
                                </div>
                            </div>

                            <!-- Contact Tab -->
                            <div class="tab-pane fade" id="add-contact" role="tabpanel">
                                <div class="row">
                                    <div class="col-md-3 mb-3">
                                        <label for="PhoneCode" class="form-label fw-semibold">Phone Code <span class="text-danger">*</span></label>
                                        <select class="form-select form-control" id="PhoneCode" required>
                                            <option value="+91" selected>+91 (India)</option>
                                            <option value="+1">+1 (USA)</option>
                                            <option value="+44">+44 (UK)</option>
                                            <option value="+971">+971 (UAE)</option>
                                            <option value="+61">+61 (Australia)</option>
                                            <option value="+65">+65 (Singapore)</option>
                                        </select>
                                        <div class="invalid-feedback">Phone Code is required.</div>
                                    </div>
                                    <div class="col-md-5 mb-3">
                                        <label for="Phone" class="form-label fw-semibold">Phone Number <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="Phone" required>
                                        <div class="invalid-feedback">Phone Number is required.</div>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="Email" class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                                        <input type="email" class="form-control" id="Email" required>
                                        <div class="invalid-feedback">Valid Email is required.</div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12 mb-3">
                                        <label for="Address" class="form-label fw-semibold">Street Address</label>
                                        <textarea class="form-control" id="Address" rows="2" placeholder="Enter street address..."></textarea>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-3 mb-3">
                                        <label for="City" class="form-label fw-semibold">City</label>
                                        <input type="text" class="form-control" id="City">
                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label for="State" class="form-label fw-semibold">State</label>
                                        <input type="text" class="form-control" id="State">
                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label for="Country" class="form-label fw-semibold">Country</label>
                                        <input type="text" class="form-control" id="Country">
                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label for="ZipCode" class="form-label fw-semibold">Zip Code</label>
                                        <input type="text" class="form-control" id="ZipCode">
                                    </div>
                                </div>
                            </div>

                            <!-- Job & Work Tab -->
                            <div class="tab-pane fade" id="add-job" role="tabpanel">
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label for="EmpCode" class="form-label fw-semibold">Employee Code <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="EmpCode" required placeholder="Generating...">
                                            <button class="btn btn-outline-secondary" type="button" onclick="regenerateEmpCode('add')" title="Regenerate code"><i data-lucide="refresh-cw" class="fs-sm"></i></button>
                                        </div>
                                        <div class="invalid-feedback">Employee Code is required.</div>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="Username" class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="Username" required>
                                        <div class="invalid-feedback">Username is required.</div>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="Password" class="form-label fw-semibold">Password <span class="text-danger">*</span></label>
                                        <input type="password" class="form-control" id="Password" required value="123456">
                                        <div class="invalid-feedback">Password is required.</div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="Company" class="form-label fw-semibold">Company Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="Company" placeholder="e.g. Zentora Corporate" required>
                                        <div class="invalid-feedback">Company Name is required.</div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="Branch" class="form-label fw-semibold">Branch <span class="text-danger">*</span></label>
                                        <select class="form-select form-control" id="Branch" required>
                                            <option value="">Loading...</option>
                                        </select>
                                        <div class="invalid-feedback">Branch is required.</div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="Department" class="form-label fw-semibold">Department <span class="text-danger">*</span></label>
                                        <select class="form-select form-control" id="Department" required>
                                            <option value="">Select Branch first...</option>
                                        </select>
                                        <div class="invalid-feedback">Department is required.</div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="SubDepartment" class="form-label fw-semibold">Sub-Department <span class="text-danger">*</span></label>
                                        <select class="form-select form-control" id="SubDepartment" required>
                                            <option value="">Select Department first...</option>
                                        </select>
                                        <div class="invalid-feedback">Sub-Department is required.</div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label for="Designation" class="form-label fw-semibold">Designation <span class="text-danger">*</span></label>
                                        <select class="form-select form-control" id="Designation" required>
                                            <option value="">Loading...</option>
                                        </select>
                                        <div class="invalid-feedback">Designation is required.</div>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="OfficeShift" class="form-label fw-semibold">Office Shift</label>
                                        <select class="form-select form-control" id="OfficeShift">
                                            <option value="">Loading...</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="OfficeLocation" class="form-label fw-semibold">Office Location</label>
                                        <input type="text" class="form-control" id="OfficeLocation" placeholder="e.g. Noida Office">
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="DOJ" class="form-label fw-semibold">Date of Joining (DOJ)</label>
                                        <input type="date" class="form-control" id="DOJ">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="DOL" class="form-label fw-semibold">Date of Leaving (DOL)</label>
                                        <input type="date" class="form-control" id="DOL">
                                    </div>
                                </div>
                            </div>

                            <!-- Relations & System Tab -->
                            <div class="tab-pane fade" id="add-relations" role="tabpanel">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="ReportingManager" class="form-label fw-semibold">Reporting Manager</label>
                                        <select class="form-select form-control" id="ReportingManager">
                                            <option value="0">None</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="AssociateReportingManager" class="form-label fw-semibold">Associate Reporting Manager</label>
                                        <select class="form-select form-control" id="AssociateReportingManager">
                                            <option value="0">None</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label for="RoleType" class="form-label fw-semibold">Role Type</label>
                                        <select class="form-select form-control" id="RoleType">
                                            <option value="5" selected>Employee</option>
                                            <option value="4">HR</option>
                                            <option value="3">Manager</option>
                                            <option value="2">Admin</option>
                                            <option value="1">Superadmin</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="ProjectRole" class="form-label fw-semibold">Project Role</label>
                                        <input type="text" class="form-control" id="ProjectRole" placeholder="e.g. Lead Dev / QA">
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="BasicSalary" class="form-label fw-semibold">Basic Salary</label>
                                        <input type="number" step="0.01" class="form-control" id="BasicSalary" value="0.00">
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="LeaveCategory" class="form-label fw-semibold">Leave Category Rule</label>
                                        <select class="form-select form-control" id="LeaveCategory">
                                            <option value="">Loading...</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="HolidayCategory" class="form-label fw-semibold">Holiday Category Rule</label>
                                        <select class="form-select form-control" id="HolidayCategory">
                                            <option value="">Loading...</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary px-4">Save Employee</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- UpdateEmp Modal -->
    <div id="UpdateEmpModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <form id="UpdateEmpForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header border-bottom-0 pb-0">
                        <h4 class="modal-title fw-bold">Update Employee Details</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="update_id" />

                        <!-- Navigation Tabs -->
                        <ul class="nav nav-pills nav-justified bg-light rounded-pill p-1 mb-4" role="tablist">
                            <li class="nav-item">
                                <button class="nav-link rounded-pill active py-2" data-bs-toggle="tab" data-bs-target="#u-personal" type="button" role="tab">Personal</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link rounded-pill py-2" data-bs-toggle="tab" data-bs-target="#u-contact" type="button" role="tab">Contact</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link rounded-pill py-2" data-bs-toggle="tab" data-bs-target="#u-job" type="button" role="tab">Job & Work</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link rounded-pill py-2" data-bs-toggle="tab" data-bs-target="#u-relations" type="button" role="tab">Relations</button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <!-- Personal Tab -->
                            <div class="tab-pane fade show active" id="u-personal" role="tabpanel">
                                <!-- Profile Photo Upload Section (Edit) -->
                                <div class="row align-items-center mb-4 bg-light-subtle p-3 rounded border border-dashed">
                                    <div class="col-auto">
                                        <div class="position-relative d-inline-block">
                                            <img id="u-avatar-preview" src="/assets/images/users/avatar-1.jpg" class="rounded-circle border border-3 border-light shadow-sm" style="width: 80px; height: 80px; object-fit: cover;" onerror="this.onerror=null; this.src='/assets/images/users/avatar-1.jpg';" />
                                            <span id="u-upload-spinner" class="spinner-border spinner-border-sm text-primary position-absolute top-50 start-50 translate-middle d-none" role="status"></span>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <h6 class="fw-bold mb-1 text-heading">Profile Photo</h6>
                                        <p class="text-muted fs-xxs mb-2">Upload a picture from your device or specify a web URL.</p>
                                        <div class="d-flex gap-2">
                                            <button type="button" class="btn btn-sm btn-soft-primary" onclick="triggerFileUpload('edit')">
                                                <i class="me-1" data-lucide="upload-cloud"></i> Upload New File
                                            </button>
                                            <button type="button" class="btn btn-sm btn-soft-secondary" onclick="toggleUrlInput('edit')">
                                                <i class="me-1" data-lucide="link-2"></i> Use URL
                                            </button>
                                        </div>
                                        <input type="file" id="file-upload-edit" class="d-none" accept="image/*" onchange="handleFileChange(this, 'edit')">
                                        <div id="url-input-container-edit" class="mt-2 d-none" style="max-width: 400px;">
                                            <input type="url" class="form-control form-control-sm" id="uProfileImage" placeholder="Paste image URL here..." oninput="handleUrlInput(this, 'edit')">
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label for="uFirstName" class="form-label fw-semibold">First Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="uFirstName" required>
                                        <div class="invalid-feedback">First Name is required.</div>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="uMiddleName" class="form-label fw-semibold">Middle Name</label>
                                        <input type="text" class="form-control" id="uMiddleName">
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="uLastName" class="form-label fw-semibold">Last Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="uLastName" required>
                                        <div class="invalid-feedback">Last Name is required.</div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4 mb-3">
