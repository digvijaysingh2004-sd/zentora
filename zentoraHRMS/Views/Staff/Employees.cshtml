<script>
    // Intercept data-choices elements before DOMContentLoaded to prevent automatic double initialization
    var choicesToClean = [
        '#Designation', '#uDesignation', '#Department', '#uDepartment', '#SubDepartment', '#uSubDepartment', 
        '#Branch', '#uBranch', '#OfficeShift', '#uOfficeShift', '#HolidayCategory', '#uHolidayCategory', 
        '#LeaveCategory', '#uLeaveCategory', '#ReportingManager', '#uReportingManager', 
        '#AssociateReportingManager', '#uAssociateReportingManager', '#Gender', '#uGender', 
        '#MaritalStatus', '#uMaritalStatus', '#PhoneCode', '#uPhoneCode', '#RoleType', '#uRoleType'
    ];
    document.querySelectorAll(choicesToClean.join(', ')).forEach(function(el) {
        el.removeAttribute('data-choices');
    });

    var designationChoice, departmentChoice, subdepartmentChoice, branchChoice;
    var uDesignationChoice, uDepartmentChoice, uSubdepartmentChoice, uBranchChoice;
    var shiftChoice, uShiftChoice, holidayChoice, uHolidayChoice, leaveChoice, uLeaveChoice;
    var managerChoice, uManagerChoice, assocManagerChoice, uAssocManagerChoice;
    var genderChoice, uGenderChoice, maritalChoice, uMaritalChoice, phoneCodeChoice, uPhoneCodeChoice, roleChoice, uRoleChoice;

    $(document).ready(function () {
        // Initialize Choices instances manually
        initChoices();

        // Load initial dropdowns
        loadInitialDropdowns();

        // Branch changes cascade
        $('#Branch').on('change', function () {
            var branchName = $(this).val();
            if (branchName) {
                $.ajax({
                    url: '/Staff/GetDepartmentsByBranch',
                    type: 'GET',
                    data: { branchName: branchName },
                    success: function (list) {
                        setSelectChoices(departmentChoice, list, 'Select Department', true);
                        setSelectChoices(subdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
                    }
                });
            } else {
                setSelectChoices(departmentChoice, [], 'Select Department (Please select Branch first)', false);
                setSelectChoices(subdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
            }
        });

        $('#uBranch').on('change', function () {
            var branchName = $(this).val();
            if (branchName) {
                $.ajax({
                    url: '/Staff/GetDepartmentsByBranch',
                    type: 'GET',
                    data: { branchName: branchName },
                    success: function (list) {
                        setSelectChoices(uDepartmentChoice, list, 'Select Department', true);
                        setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
                    }
                });
            } else {
                setSelectChoices(uDepartmentChoice, [], 'Select Department (Please select Branch first)', false);
                setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
            }
        });

        // Department changes cascade
        $('#Department').on('change', function () {
            var departmentName = $(this).val();
            if (departmentName) {
                $.ajax({
                    url: '/Staff/GetSubDepartmentsByDepartment',
                    type: 'GET',
                    data: { departmentName: departmentName },
                    success: function (list) {
                        setSelectChoices(subdepartmentChoice, list, 'Select Sub-Department', true);
                    }
                });
            } else {
                setSelectChoices(subdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
            }
        });

        $('#uDepartment').on('change', function () {
            var departmentName = $(this).val();
            if (departmentName) {
                $.ajax({
                    url: '/Staff/GetSubDepartmentsByDepartment',
                    type: 'GET',
                    data: { departmentName: departmentName },
                    success: function (list) {
                        setSelectChoices(uSubdepartmentChoice, list, 'Select Sub-Department', true);
                    }
                });
            } else {
                setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
            }
        });

        $("#EmpForm").on("submit", function (e) {
            e.preventDefault();
            if (!validateForm('EmpForm')) {
                return false;
            }
            var formData = {
                EmpCode: $("#EmpCode").val(),
                Username: $("#Username").val(),
                Password: $("#Password").val(),
                FirstName: $("#FirstName").val(),
                MiddleName: $("#MiddleName").val(),
                LastName: $("#LastName").val(),
                Gender: $("#Gender").val(),
                MaritalStatus: $("#MaritalStatus").val(),
                DOB: $("#DOB").val() || null,
                ProfileImage: $("#ProfileImage").val(),
                PhoneCode: $("#PhoneCode").val(),
                Phone: $("#Phone").val(),
                Email: $("#Email").val(),
                Address: $("#Address").val(),
                City: $("#City").val(),
                State: $("#State").val(),
                Country: $("#Country").val(),
                ZipCode: $("#ZipCode").val(),
                Designation: $("#Designation").val(),
                Company: $("#Company").val(),
                Branch: $("#Branch").val(),
                Department: $("#Department").val(),
                SubDepartment: $("#SubDepartment").val(),
                OfficeShift: $("#OfficeShift").val(),
                OfficeLocation: $("#OfficeLocation").val(),
                DOJ: $("#DOJ").val() || null,
                DOL: $("#DOL").val() || null,
                RoleType: parseInt($("#RoleType").val()) || 5,
                ProjectRole: $("#ProjectRole").val(),
                ReportingManager: parseInt($("#ReportingManager").val()) || 0,
                AssociateReportingManager: parseInt($("#AssociateReportingManager").val()) || 0,
                LeaveCategory: $("#LeaveCategory").val(),
                HolidayCategory: $("#HolidayCategory").val(),
                BasicSalary: parseFloat($("#BasicSalary").val()) || 0.0,
                IsActive: true
            };
            $.ajax({
                url: '/Staff/SaveEmployee',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        $("#UpdateEmpForm").on("submit", function (e) {
            e.preventDefault();
            if (!validateForm('UpdateEmpForm')) {
                return false;
            }
            var formData = {
                Id: $("#update_id").val(),
                EmpCode: $("#uEmpCode").val(),
                Username: $("#uUsername").val(),
                Password: $("#uPassword").val(),
                FirstName: $("#uFirstName").val(),
                MiddleName: $("#uMiddleName").val(),
                LastName: $("#uLastName").val(),
                Gender: $("#uGender").val(),
                MaritalStatus: $("#uMaritalStatus").val(),
                DOB: $("#uDOB").val() || null,
                ProfileImage: $("#uProfileImage").val(),
                PhoneCode: $("#uPhoneCode").val(),
                Phone: $("#uPhone").val(),
                Email: $("#uEmail").val(),
                Address: $("#uAddress").val(),
                City: $("#uCity").val(),
                State: $("#uState").val(),
                Country: $("#uCountry").val(),
                ZipCode: $("#uZipCode").val(),
                Designation: $("#uDesignation").val(),
                Company: $("#uCompany").val(),
                Branch: $("#uBranch").val(),
                Department: $("#uDepartment").val(),
                SubDepartment: $("#uSubDepartment").val(),
                OfficeShift: $("#uOfficeShift").val(),
                OfficeLocation: $("#uOfficeLocation").val(),
                DOJ: $("#uDOJ").val() || null,
                DOL: $("#uDOL").val() || null,
                RoleType: parseInt($("#uRoleType").val()) || 5,
                ProjectRole: $("#uProjectRole").val(),
                ReportingManager: parseInt($("#uReportingManager").val()) || 0,
                AssociateReportingManager: parseInt($("#uAssociateReportingManager").val()) || 0,
                LeaveCategory: $("#uLeaveCategory").val(),
                HolidayCategory: $("#uHolidayCategory").val(),
                IsActive: $("#uIsActive").is(":checked")
            };
            $.ajax({
                url: '/Staff/UpdateEmployee',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });
    });

    function initChoices() {
        designationChoice = new Choices('#Designation', { searchEnabled: true, shouldSort: false });
        departmentChoice = new Choices('#Department', { searchEnabled: true, shouldSort: false });
        subdepartmentChoice = new Choices('#SubDepartment', { searchEnabled: true, shouldSort: false });
        branchChoice = new Choices('#Branch', { searchEnabled: true, shouldSort: false });
        shiftChoice = new Choices('#OfficeShift', { searchEnabled: true, shouldSort: false });
        holidayChoice = new Choices('#HolidayCategory', { searchEnabled: true, shouldSort: false });
        leaveChoice = new Choices('#LeaveCategory', { searchEnabled: true, shouldSort: false });
        managerChoice = new Choices('#ReportingManager', { searchEnabled: true, shouldSort: false });
        assocManagerChoice = new Choices('#AssociateReportingManager', { searchEnabled: true, shouldSort: false });
        genderChoice = new Choices('#Gender', { searchEnabled: false, shouldSort: false });
        maritalChoice = new Choices('#MaritalStatus', { searchEnabled: false, shouldSort: false });
        phoneCodeChoice = new Choices('#PhoneCode', { searchEnabled: true, shouldSort: false });
        roleChoice = new Choices('#RoleType', { searchEnabled: false, shouldSort: false });

        uDesignationChoice = new Choices('#uDesignation', { searchEnabled: true, shouldSort: false });
        uDepartmentChoice = new Choices('#uDepartment', { searchEnabled: true, shouldSort: false });
        uSubdepartmentChoice = new Choices('#uSubDepartment', { searchEnabled: true, shouldSort: false });
        uBranchChoice = new Choices('#uBranch', { searchEnabled: true, shouldSort: false });
        uShiftChoice = new Choices('#uOfficeShift', { searchEnabled: true, shouldSort: false });
        uHolidayChoice = new Choices('#uHolidayCategory', { searchEnabled: true, shouldSort: false });
        uLeaveChoice = new Choices('#uLeaveCategory', { searchEnabled: true, shouldSort: false });
        uManagerChoice = new Choices('#uReportingManager', { searchEnabled: true, shouldSort: false });
        uAssocManagerChoice = new Choices('#uAssociateReportingManager', { searchEnabled: true, shouldSort: false });
        uGenderChoice = new Choices('#uGender', { searchEnabled: false, shouldSort: false });
        uMaritalChoice = new Choices('#uMaritalStatus', { searchEnabled: false, shouldSort: false });
        uPhoneCodeChoice = new Choices('#uPhoneCode', { searchEnabled: true, shouldSort: false });
        uRoleChoice = new Choices('#uRoleType', { searchEnabled: false, shouldSort: false });
    }

    function setSelectChoices(choiceInstance, list, placeholderText, enabled) {
        choiceInstance.clearStore();
        
        var choicesArray = [];
        if (placeholderText) {
            choicesArray.push({
                value: '',
                label: placeholderText,
                selected: true,
                disabled: true
            });
        }
        
        $.each(list, function (i, item) {
            choicesArray.push({
                value: item,
                label: item,
                selected: false,
                disabled: false
            });
        });
        
        choiceInstance.setChoices(choicesArray, 'value', 'label', true);
        if (enabled) {
            choiceInstance.enable();
        } else {
            choiceInstance.disable();
        }
    }

    function setEmployeeDropdownChoices(choiceInstance, list, placeholderText) {
        choiceInstance.clearStore();
        var choicesArray = [{
            value: '0',
            label: placeholderText || 'None',
            selected: true,
            disabled: false
        }];

        $.each(list, function(i, item) {
            choicesArray.push({
                value: item.Id.toString(),
                label: item.FirstName + ' ' + (item.MiddleName ? item.MiddleName + ' ' : '') + item.LastName + ' (' + item.Username + ')',
                selected: false,
                disabled: false
            });
        });
        choiceInstance.setChoices(choicesArray, 'value', 'label', true);
    }

    function loadInitialDropdowns() {
        $.ajax({
            url: '/Staff/GetDesignationsList',
            type: 'GET',
            success: function (list) {
                setSelectChoices(designationChoice, list, 'Select Designation', true);
                setSelectChoices(uDesignationChoice, list, 'Select Designation', true);
            }
        });

        $.ajax({
            url: '/Staff/GetBranchesList',
            type: 'GET',
            success: function (list) {
                setSelectChoices(branchChoice, list, 'Select Branch', true);
                setSelectChoices(uBranchChoice, list, 'Select Branch', true);
            }
        });

        $.ajax({
            url: '/Staff/GetShiftsList',
            type: 'GET',
            success: function (list) {
                setSelectChoices(shiftChoice, list, 'Select Shift', true);
                setSelectChoices(uShiftChoice, list, 'Select Shift', true);
            }
        });

        $.ajax({
            url: '/Staff/GetHolidayCategoriesList',
            type: 'GET',
            success: function (list) {
                setSelectChoices(holidayChoice, list, 'Select Holiday Category Rule', true);
                setSelectChoices(uHolidayChoice, list, 'Select Holiday Category Rule', true);
            }
        });

        $.ajax({
            url: '/Staff/GetLeaveCategoriesList',
            type: 'GET',
            success: function (list) {
                setSelectChoices(leaveChoice, list, 'Select Leave Category Rule', true);
                setSelectChoices(uLeaveChoice, list, 'Select Leave Category Rule', true);
            }
        });

        // Load Reporting Managers
        $.ajax({
            url: '/Staff/GetEmployeeList',
            type: 'GET',
            success: function (list) {
                setEmployeeDropdownChoices(managerChoice, list, 'None (Reporting Manager)');
                setEmployeeDropdownChoices(uManagerChoice, list, 'None (Reporting Manager)');
                setEmployeeDropdownChoices(assocManagerChoice, list, 'None (Associate Reporting Manager)');
                setEmployeeDropdownChoices(uAssocManagerChoice, list, 'None (Associate Reporting Manager)');
            }
        });
        
        // Initially disable Department and SubDepartment
        setSelectChoices(departmentChoice, [], 'Select Department (Please select Branch first)', false);
        setSelectChoices(uDepartmentChoice, [], 'Select Department (Please select Branch first)', false);
        setSelectChoices(subdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
        setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
    }

    // Generate/Regenerate Next Employee Code
    function regenerateEmpCode(type) {
        var inputId = type === 'add' ? '#EmpCode' : '#uEmpCode';
        $(inputId).val('').attr('placeholder', 'Generating...');
        $.ajax({
            url: '/Staff/GetNextEmployeeCode',
            type: 'GET',
            success: function (res) {
                if (res.success) {
                    $(inputId).val(res.code).attr('placeholder', '');
                } else {
                    $(inputId).val('').attr('placeholder', 'Error generating code');
                }
            },
            error: function () {
                $(inputId).val('').attr('placeholder', 'Error generating code');
            }
        });
    }

    // Trigger File Input Click
    function triggerFileUpload(type) {
        var uploadId = type === 'add' ? '#file-upload-add' : '#file-upload-edit';
        $(uploadId).click();
    }

    // Toggle URL Container Visibility
    function toggleUrlInput(type) {
        var containerId = type === 'add' ? '#url-input-container-add' : '#url-input-container-edit';
        $(containerId).toggleClass('d-none');
    }

    // Handles URL Text Input Change for instant preview
    function handleUrlInput(input, type) {
        var url = $(input).val();
        var previewId = type === 'add' ? '#avatar-preview' : '#u-avatar-preview';
        if (url && url.trim() !== '') {
            $(previewId).attr('src', url);
        } else {
            $(previewId).attr('src', '/assets/images/users/avatar-1.jpg');
        }
    }

    // Handle File Input Change (AJAX upload + Preview update)
    function handleFileChange(input, type) {
        if (input.files && input.files[0]) {
            var file = input.files[0];
            var formData = new FormData();
            formData.append("file", file);

            var spinnerId = type === 'add' ? '#upload-spinner' : '#u-upload-spinner';
            var previewId = type === 'add' ? '#avatar-preview' : '#u-avatar-preview';
            var urlInputId = type === 'add' ? '#ProfileImage' : '#uProfileImage';

            $(spinnerId).removeClass('d-none');

            $.ajax({
                url: '/Staff/UploadProfileImage',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function (res) {
                    $(spinnerId).addClass('d-none');
                    if (res.success) {
                        $(previewId).attr('src', res.url);
                        $(urlInputId).val(res.url);
                    } else {
                        alert("Upload failed: " + res.message);
                    }
                },
                error: function () {
                    $(spinnerId).addClass('d-none');
                    alert("Error while uploading profile image.");
                }
            });
        }
    }

    function OpenAddModal() {
        // Reset form and reset choices
        $('#EmpForm')[0].reset();
        
        // Reset choices values to defaults
        genderChoice.setChoiceByValue("");
        maritalChoice.setChoiceByValue("");
        phoneCodeChoice.setChoiceByValue("+91");
        branchChoice.setChoiceByValue("");
        designationChoice.setChoiceByValue("");
        shiftChoice.setChoiceByValue("");
        holidayChoice.setChoiceByValue("");
        leaveChoice.setChoiceByValue("");
        managerChoice.setChoiceByValue("0");
        assocManagerChoice.setChoiceByValue("0");
        roleChoice.setChoiceByValue("5");
        
        setSelectChoices(departmentChoice, [], 'Select Department (Please select Branch first)', false);
        setSelectChoices(subdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);

        // Fetch auto-generated next employee code
        regenerateEmpCode('add');

        // Reset profile avatar image and hide url container
        $('#avatar-preview').attr('src', '/assets/images/users/avatar-1.jpg');
        $('#url-input-container-add').addClass('d-none');

        // Open first tab by default
        var tabTrigger = new bootstrap.Tab(document.querySelector('#AddEmpModal button[data-bs-target="#add-personal"]'));
        tabTrigger.show();

        $('#AddEmpModal').modal('show');
    }

    function validateForm(formId) {
        var isValid = true;
        
        // Remove all previous validation styling
        $('#' + formId + ' .is-invalid').removeClass('is-invalid');
        $('#' + formId + ' .choices').removeClass('is-invalid');
        
        var isUpdate = (formId === 'UpdateEmpForm');
        var prefix = isUpdate ? 'u' : '';
        
        var fields = [
            { id: prefix + 'EmpCode', name: 'Employee Code', isSelect: false },
            { id: prefix + 'Username', name: 'Username', isSelect: false },
            { id: prefix + 'Password', name: 'Password', isSelect: false },
            { id: prefix + 'FirstName', name: 'First Name', isSelect: false },
            { id: prefix + 'LastName', name: 'Last Name', isSelect: false },
            { id: prefix + 'Phone', name: 'Phone', isSelect: false },
            { id: prefix + 'Email', name: 'Email', isSelect: false },
            { id: prefix + 'Designation', name: 'Designation', isSelect: true },
            { id: prefix + 'Department', name: 'Department', isSelect: true },
            { id: prefix + 'SubDepartment', name: 'Sub-Department', isSelect: true },
            { id: prefix + 'Branch', name: 'Branch', isSelect: true },
            { id: prefix + 'Company', name: 'Company', isSelect: false },
            { id: prefix + 'PhoneCode', name: 'Phone Code', isSelect: true }
        ];
        
        $.each(fields, function (i, field) {
            var $el = $('#' + field.id);
            var val = $el.val();
            
            if (!val || val.trim() === '') {
                isValid = false;
                $el.addClass('is-invalid');
                
                var $container = field.isSelect ? $el.closest('.choices') : $el;
                if (field.isSelect) {
                    $container.addClass('is-invalid');
                }
                
                var $feedback = $container.siblings('.invalid-feedback');
                var msg = field.isSelect ? 'Please select the ' + field.name + '.' : 'Please enter the ' + field.name + '.';
                if ($feedback.length === 0) {
                    $container.parent().append('<div class="invalid-feedback">' + msg + '</div>');
                } else {
                    $feedback.text(msg);
                }
            }
        });

        // If not valid, activate the first tab containing invalid inputs
        if (!isValid) {
            var $firstInvalid = $('#' + formId + ' .is-invalid').first();
            var $tabPane = $firstInvalid.closest('.tab-pane');
            if ($tabPane.length > 0) {
                var paneId = $tabPane.attr('id');
                var tabBtn = document.querySelector('#' + formId + ' button[data-bs-target="#' + paneId + '"]');
                if (tabBtn) {
                    var tabInstance = new bootstrap.Tab(tabBtn);
                    tabInstance.show();
                }
            }
        }
        
        return isValid;
    }

    function formatJsonDate(jsonDateString) {
        if (!jsonDateString) return '';
        try {
            var date = new Date(parseInt(jsonDateString.substr(6)));
            if (isNaN(date.getTime())) return '';
            var formatted = date.getFullYear() + '-' + ('0' + (date.getMonth() + 1)).slice(-2) + '-' + ('0' + date.getDate()).slice(-2);
            return formatted;
        } catch(e) {
            return '';
        }
    }

    function UpdateEmp(id) {
        $.ajax({
            url: '/Staff/GetEmployeeById',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                if (data) {
                    // Reset form first
                    $('#UpdateEmpForm')[0].reset();

                    $("#update_id").val(data.Id);
                    $("#uEmpCode").val(data.EmpCode);
                    $("#uUsername").val(data.Username);
                    $("#uPassword").val(data.Password || "123456");
                    $("#uFirstName").val(data.FirstName);
                    $("#uMiddleName").val(data.MiddleName);
                    $("#uLastName").val(data.LastName);
                    $("#uPhone").val(data.Phone);
                    $("#uEmail").val(data.Email);
                    $("#uCompany").val(data.Company);
                    $("#uOfficeLocation").val(data.OfficeLocation);
                    $("#uProjectRole").val(data.ProjectRole);
                    $("#uAddress").val(data.Address);
                    $("#uCity").val(data.City);
                    $("#uState").val(data.State);
                    $("#uCountry").val(data.Country);
                    $("#uZipCode").val(data.ZipCode);
                    $("#uProfileImage").val(data.ProfileImage);
                    
                    // Reset photo preview in Edit modal
                    if (data.ProfileImage && data.ProfileImage.trim() !== '') {
                        $('#u-avatar-preview').attr('src', data.ProfileImage);
                    } else {
                        $('#u-avatar-preview').attr('src', '/assets/images/users/avatar-1.jpg');
                    }
                    $('#url-input-container-edit').addClass('d-none');

                    // Toggle Active Status
                    $("#uIsActive").prop("checked", data.IsActive);

                    // Formatted Dates
                    $("#uDOB").val(formatJsonDate(data.DOB));
                    $("#uDOJ").val(formatJsonDate(data.DOJ));
                    $("#uDOL").val(formatJsonDate(data.DOL));

                    // Choices setting values
                    genderChoice.setChoiceByValue(data.Gender || "");
                    maritalChoice.setChoiceByValue(data.MaritalStatus || "");
                    phoneCodeChoice.setChoiceByValue(data.PhoneCode || "+91");
                    designationChoice.setChoiceByValue(data.Designation || "");
                    shiftChoice.setChoiceByValue(data.OfficeShift || "");
                    holidayChoice.setChoiceByValue(data.HolidayCategory || "");
                    leaveChoice.setChoiceByValue(data.LeaveCategory || "");
                    
                    managerChoice.setChoiceByValue((data.ReportingManager || 0).toString());
                    assocManagerChoice.setChoiceByValue((data.AssociateReportingManager || 0).toString());
                    roleChoice.setChoiceByValue((data.RoleType || 5).toString());
                    
                    // Trigger Cascades sequentially
                    uDesignationChoice.setChoiceByValue(data.Designation);
                    uBranchChoice.setChoiceByValue(data.Branch);
                    uShiftChoice.setChoiceByValue(data.OfficeShift);
                    uHolidayChoice.setChoiceByValue(data.HolidayCategory);
                    uLeaveChoice.setChoiceByValue(data.LeaveCategory);
                    uManagerChoice.setChoiceByValue((data.ReportingManager || 0).toString());
                    uAssocManagerChoice.setChoiceByValue((data.AssociateReportingManager || 0).toString());
                    uRoleChoice.setChoiceByValue((data.RoleType || 5).toString());
                    uGenderChoice.setChoiceByValue(data.Gender || "");
                    uMaritalChoice.setChoiceByValue(data.MaritalStatus || "");
                    uPhoneCodeChoice.setChoiceByValue(data.PhoneCode || "+91");

                    if (data.Branch) {
                        $.ajax({
                            url: '/Staff/GetDepartmentsByBranch',
                            type: 'GET',
                            data: { branchName: data.Branch },
                            success: function (deptList) {
                                setSelectChoices(uDepartmentChoice, deptList, 'Select Department', true);
                                uDepartmentChoice.setChoiceByValue(data.Department);
                                
                                if (data.Department) {
                                    $.ajax({
                                        url: '/Staff/GetSubDepartmentsByDepartment',
                                        type: 'GET',
                                        data: { departmentName: data.Department },
                                        success: function (subDeptList) {
                                            setSelectChoices(uSubdepartmentChoice, subDeptList, 'Select Sub-Department', true);
                                            uSubdepartmentChoice.setChoiceByValue(data.SubDepartment);
                                            
                                            // Open first tab by default
                                            var tabTrigger = new bootstrap.Tab(document.querySelector('#UpdateEmpModal button[data-bs-target="#u-personal"]'));
                                            tabTrigger.show();

                                            $("#UpdateEmpModal").modal("show");
                                        }
                                    });
                                } else {
                                    setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
                                    
                                    // Open first tab by default
                                    var tabTrigger = new bootstrap.Tab(document.querySelector('#UpdateEmpModal button[data-bs-target="#u-personal"]'));
                                    tabTrigger.show();

                                    $("#UpdateEmpModal").modal("show");
                                }
                            }
                        });
                    } else {
                        setSelectChoices(uDepartmentChoice, [], 'Select Department (Please select Branch first)', false);
                        setSelectChoices(uSubdepartmentChoice, [], 'Select Sub-Department (Please select Department first)', false);
                        
                        // Open first tab by default
                        var tabTrigger = new bootstrap.Tab(document.querySelector('#UpdateEmpModal button[data-bs-target="#u-personal"]'));
                        tabTrigger.show();

                        $("#UpdateEmpModal").modal("show");
                    }
                }
            }
        });
    }

    function DeleteEmp(id) {
        if (confirm("Are you sure you want to delete this employee?")) {
            $.ajax({
                url: '/Staff/DeleteEmployee',
                type: "POST",
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        }
    }
</script>
