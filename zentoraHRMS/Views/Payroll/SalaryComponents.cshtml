@model IEnumerable<zentoraHRMS.Models.SalaryComponentModel>
@{
    ViewBag.Title = "Salary Components";
}

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">Salary Components</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title">Earnings & Deductions</h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" data-bs-toggle="modal" data-bs-target="#AddComponent">
                        <i class="me-1" data-lucide="plus"></i> Add Component
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Component ID</th>
                                <th>Component Name</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td>@c.ComponentId</td>
                                    <td>@c.ComponentName</td>
                                    <td>
                                        @if (c.ComponentType == "Earning") { <span class="badge bg-success-subtle text-success">Earning</span> }
                                        else { <span class="badge bg-danger-subtle text-danger">Deduction</span> }
                                    </td>
                                    <td>@c.Description</td>
                                    <td>
                                        <a onclick="UpdateComponent(@c.ComponentId)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeleteComponent(@c.ComponentId)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddComponent Modal -->
    <div id="AddComponent" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="ComponentForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Add Salary Component</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="ComponentName" class="form-label">Component Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="ComponentName" required>
                        </div>
                        <div class="mb-3">
                            <label for="ComponentType" class="form-label">Component Type <span class="text-danger">*</span></label>
                            <select id="ComponentType" class="form-select" required>
                                <option value="Earning" selected>Earning</option>
                                <option value="Deduction">Deduction</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="Description" class="form-label">Description</label>
                            <textarea class="form-control" id="Description" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- UpdateComponent Modal -->
    <div id="UpdateComponentModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="UpdateComponentForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Update Salary Component</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="update_id" />
                        <div class="mb-3">
                            <label for="uComponentName" class="form-label">Component Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="uComponentName" required>
                        </div>
                        <div class="mb-3">
                            <label for="uComponentType" class="form-label">Component Type <span class="text-danger">*</span></label>
                            <select id="uComponentType" class="form-select" required>
                                <option value="Earning">Earning</option>
                                <option value="Deduction">Deduction</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="uDescription" class="form-label">Description</label>
                            <textarea class="form-control" id="uDescription" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#ComponentForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                ComponentName: $("#ComponentName").val(),
                ComponentType: $("#ComponentType").val(),
                Description: $("#Description").val()
            };
            $.ajax({
                url: '/Payroll/SaveComponent',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        $("#UpdateComponentForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                ComponentId: $("#update_id").val(),
                ComponentName: $("#uComponentName").val(),
                ComponentType: $("#uComponentType").val(),
                Description: $("#uDescription").val()
            };
            $.ajax({
                url: '/Payroll/UpdateComponent',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });
    });

    function UpdateComponent(id) {
        $.ajax({
            url: '/Payroll/GetComponentById',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                if (data) {
                    $("#update_id").val(data.ComponentId);
                    $("#uComponentName").val(data.ComponentName);
                    $("#uComponentType").val(data.ComponentType);
                    $("#uDescription").val(data.Description);
                    $("#UpdateComponentModal").modal("show");
                }
            }
        });
    }

    function DeleteComponent(id) {
        if (confirm("Are you sure you want to delete this component?")) {
            $.ajax({
                url: '/Payroll/DeleteComponent',
                type: "POST",
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        }
    }
</script>
