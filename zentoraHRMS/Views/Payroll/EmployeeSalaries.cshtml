@model IEnumerable<zentoraHRMS.Models.EmployeeSalaryModel>
@{
    ViewBag.Title = "Employee Salaries";
}

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">Employee Salaries Setup</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title">Salary Configurations</h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" data-bs-toggle="modal" data-bs-target="#AddSalary">
                        <i class="me-1" data-lucide="plus"></i> Setup Employee Salary
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Employee</th>
                                <th>Basic Salary</th>
                                <th>Allowances</th>
                                <th>Deductions</th>
                                <th>Net Salary</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                var net = c.BasicSalary + c.Allowance - c.Deduction;
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td class="fw-bold">@c.EmployeeName</td>
                                    <td>$@c.BasicSalary.ToString("N2")</td>
                                    <td class="text-success">+$@c.Allowance.ToString("N2")</td>
                                    <td class="text-danger">-$@c.Deduction.ToString("N2")</td>
                                    <td class="fw-bold text-primary">$@net.ToString("N2")</td>
                                    <td>
                                        <a onclick="UpdateSalary(@c.SalaryId)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeleteSalary(@c.SalaryId)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddSalary Modal -->
    <div id="AddSalary" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="SalaryForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Setup Employee Salary</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="EmployeeId" class="form-label">Employee <span class="text-danger">*</span></label>
                            <select id="EmployeeId" class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="BasicSalary" class="form-label">Basic Salary <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" class="form-control" id="BasicSalary" required>
                        </div>
                        <div class="mb-3">
                            <label for="Allowance" class="form-label">Allowances</label>
                            <input type="number" step="0.01" class="form-control" id="Allowance" value="0">
                        </div>
                        <div class="mb-3">
                            <label for="Deduction" class="form-label">Deductions</label>
                            <input type="number" step="0.01" class="form-control" id="Deduction" value="0">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- UpdateSalary Modal -->
    <div id="UpdateSalaryModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="UpdateSalaryForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Update Salary Configuration</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="update_id" />
                        <div class="mb-3">
                            <label for="uEmployeeId" class="form-label">Employee <span class="text-danger">*</span></label>
                            <select id="uEmployeeId" class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="uBasicSalary" class="form-label">Basic Salary <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" class="form-control" id="uBasicSalary" required>
                        </div>
                        <div class="mb-3">
                            <label for="uAllowance" class="form-label">Allowances</label>
                            <input type="number" step="0.01" class="form-control" id="uAllowance">
                        </div>
                        <div class="mb-3">
                            <label for="uDeduction" class="form-label">Deductions</label>
                            <input type="number" step="0.01" class="form-control" id="uDeduction">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $.ajax({
            url: '/Staff/GetEmployeeList',
            type: 'GET',
            success: function (data) {
                var s = '<option value="" selected disabled>Select Employee</option>';
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].Id + '">' + data[i].FirstName + ' ' + data[i].LastName + '</option>';
                }
                $("#EmployeeId").html(s);
                $("#uEmployeeId").html(s);
            }
        });

        $("#SalaryForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                EmployeeId: $("#EmployeeId").val(),
                BasicSalary: $("#BasicSalary").val(),
                Allowance: $("#Allowance").val(),
                Deduction: $("#Deduction").val()
            };
            $.ajax({
                url: '/Payroll/SaveSalary',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        $("#UpdateSalaryForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                SalaryId: $("#update_id").val(),
                EmployeeId: $("#uEmployeeId").val(),
                BasicSalary: $("#uBasicSalary").val(),
                Allowance: $("#uAllowance").val(),
                Deduction: $("#uDeduction").val()
            };
            $.ajax({
                url: '/Payroll/UpdateSalary',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });
    });

    function UpdateSalary(id) {
        $.ajax({
            url: '/Payroll/GetSalaryById',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                if (data) {
                    $("#update_id").val(data.SalaryId);
                    $("#uEmployeeId").val(data.EmployeeId);
                    $("#uBasicSalary").val(data.BasicSalary);
                    $("#uAllowance").val(data.Allowance);
                    $("#uDeduction").val(data.Deduction);
                    $("#UpdateSalaryModal").modal("show");
                }
            }
        });
    }

    function DeleteSalary(id) {
        if (confirm("Are you sure you want to delete this salary setup?")) {
            $.ajax({
                url: '/Payroll/DeleteSalary',
                type: "POST",
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        }
    }
</script>
