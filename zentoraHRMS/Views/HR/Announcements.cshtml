@model IEnumerable<zentoraHRMS.Models.AnnouncementModel>
@{
    ViewBag.Title = "Notice & Announcements";
}

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">Announcements List</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title">Notice Details</h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" data-bs-toggle="modal" data-bs-target="#AddAnn">
                        <i class="me-1" data-lucide="plus"></i> Add Announcement
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Title</th>
                                <th>Description</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Created By</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td class="fw-bold text-primary">@c.Title</td>
                                    <td>@c.Description</td>
                                    <td>@c.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@c.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>@c.CreatedBy</td>
                                    <td>
                                        <a onclick="UpdateAnn(@c.AnnouncementId)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeleteAnn(@c.AnnouncementId)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddAnn Modal -->
    <div id="AddAnn" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="AnnForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Add Announcement</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="Title" class="form-label">Title <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="Title" required>
                        </div>
                        <div class="mb-3">
                            <label for="Description" class="form-label">Description</label>
                            <textarea class="form-control" id="Description" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="StartDate" class="form-label">Start Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="StartDate" required>
                        </div>
                        <div class="mb-3">
                            <label for="EndDate" class="form-label">End Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="EndDate" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- UpdateAnn Modal -->
    <div id="UpdateAnnModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="UpdateAnnForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Update Announcement</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="update_id" />
                        <div class="mb-3">
                            <label for="uTitle" class="form-label">Title <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="uTitle" required>
                        </div>
                        <div class="mb-3">
                            <label for="uDescription" class="form-label">Description</label>
                            <textarea class="form-control" id="uDescription" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="uStartDate" class="form-label">Start Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="uStartDate" required>
                        </div>
                        <div class="mb-3">
                            <label for="uEndDate" class="form-label">End Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="uEndDate" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#AnnForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                Title: $("#Title").val(),
                Description: $("#Description").val(),
                StartDate: $("#StartDate").val(),
                EndDate: $("#EndDate").val()
            };
            $.ajax({
                url: '/HR/SaveAnnouncement',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        $("#UpdateAnnForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                AnnouncementId: $("#update_id").val(),
                Title: $("#uTitle").val(),
                Description: $("#uDescription").val(),
                StartDate: $("#uStartDate").val(),
                EndDate: $("#uEndDate").val()
            };
            $.ajax({
                url: '/HR/UpdateAnnouncement',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });
    });

    function UpdateAnn(id) {
        $.ajax({
            url: '/HR/GetAnnouncementById',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                if (data) {
                    $("#update_id").val(data.AnnouncementId);
                    $("#uTitle").val(data.Title);
                    $("#uDescription").val(data.Description);
                    if (data.StartDate) {
                        var date = new Date(parseInt(data.StartDate.substr(6)));
                        var formattedDate = date.getFullYear() + '-' + ('0' + (date.getMonth() + 1)).slice(-2) + '-' + ('0' + date.getDate()).slice(-2);
                        $("#uStartDate").val(formattedDate);
                    }
                    if (data.EndDate) {
                        var date = new Date(parseInt(data.EndDate.substr(6)));
                        var formattedDate = date.getFullYear() + '-' + ('0' + (date.getMonth() + 1)).slice(-2) + '-' + ('0' + date.getDate()).slice(-2);
                        $("#uEndDate").val(formattedDate);
                    }
                    $("#UpdateAnnModal").modal("show");
                }
            }
        });
    }

    function DeleteAnn(id) {
        if (confirm("Are you sure you want to delete this announcement?")) {
            $.ajax({
                url: '/HR/DeleteAnnouncement',
                type: "POST",
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        }
    }
</script>
