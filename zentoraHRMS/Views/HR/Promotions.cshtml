@model IEnumerable<zentoraHRMS.Models.PromotionModel>
@{
    ViewBag.Title = "Employee Promotions";
}

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">Promotions List</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title">Promotion Details</h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" data-bs-toggle="modal" data-bs-target="#AddPromo">
                        <i class="me-1" data-lucide="plus"></i> Add Promotion
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Employee</th>
                                <th>New Designation</th>
                                <th>Promotion Date</th>
                                <th>Description</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td>@c.EmployeeName</td>
                                    <td>@c.DesignationName</td>
                                    <td>@c.PromotionDate.ToString("yyyy-MM-dd")</td>
                                    <td>@c.Description</td>
                                    <td>
                                        <a onclick="UpdatePromo(@c.PromotionId)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeletePromo(@c.PromotionId)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddPromo Modal -->
    <div id="AddPromo" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="PromoForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Add Promotion</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="EmployeeId" class="form-label">Employee <span class="text-danger">*</span></label>
                            <select id="EmployeeId" class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="DesignationId" class="form-label">New Designation <span class="text-danger">*</span></label>
                            <select id="DesignationId" class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="PromotionDate" class="form-label">Promotion Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="PromotionDate" required>
                        </div>
                        <div class="mb-3">
                            <label for="Description" class="form-label">Description</label>
                            <textarea class="form-control" id="Description" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- UpdatePromo Modal -->
    <div id="UpdatePromoModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="UpdatePromoForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Update Promotion</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="update_id" />
                        <div class="mb-3">
                            <label for="uEmployeeId" class="form-label">Employee <span class="text-danger">*</span></label>
                            <select id="uEmployeeId" class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="uDesignationId" class="form-label">New Designation <span class="text-danger">*</span></label>
                            <select id="uDesignationId" class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="uPromotionDate" class="form-label">Promotion Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="uPromotionDate" required>
                        </div>
                        <div class="mb-3">
                            <label for="uDescription" class="form-label">Description</label>
                            <textarea class="form-control" id="uDescription" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $.ajax({
            url: '/Staff/GetEmployeeList',
            type: 'GET',
            success: function (data) {
                var s = '<option value="" selected disabled>Select Employee</option>';
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].Id + '">' + data[i].FirstName + ' ' + data[i].LastName + '</option>';
                }
                $("#EmployeeId").html(s);
                $("#uEmployeeId").html(s);
            }
        });

        $.ajax({
            url: '/HR/GetDesignationsList',
            type: 'GET',
            success: function (data) {
                var s = '<option value="" selected disabled>Select Designation</option>';
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].DesignationId + '">' + data[i].DesignationName + '</option>';
                }
                $("#DesignationId").html(s);
                $("#uDesignationId").html(s);
            }
        });

        $("#PromoForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                EmployeeId: $("#EmployeeId").val(),
                DesignationId: $("#DesignationId").val(),
                PromotionDate: $("#PromotionDate").val(),
                Description: $("#Description").val()
            };
            $.ajax({
                url: '/HR/SavePromotion',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        $("#UpdatePromoForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                PromotionId: $("#update_id").val(),
                EmployeeId: $("#uEmployeeId").val(),
                DesignationId: $("#uDesignationId").val(),
                PromotionDate: $("#uPromotionDate").val(),
                Description: $("#uDescription").val()
            };
            $.ajax({
                url: '/HR/UpdatePromotion',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });
    });

    function UpdatePromo(id) {
        $.ajax({
            url: '/HR/GetPromotionById',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                if (data) {
                    $("#update_id").val(data.PromotionId);
                    $("#uEmployeeId").val(data.EmployeeId);
                    $("#uDesignationId").val(data.DesignationId);
                    if (data.PromotionDate) {
                        var date = new Date(parseInt(data.PromotionDate.substr(6)));
                        var formattedDate = date.getFullYear() + '-' + ('0' + (date.getMonth() + 1)).slice(-2) + '-' + ('0' + date.getDate()).slice(-2);
                        $("#uPromotionDate").val(formattedDate);
                    }
                    $("#uDescription").val(data.Description);
                    $("#UpdatePromoModal").modal("show");
                }
            }
        });
    }

    function DeletePromo(id) {
        if (confirm("Are you sure you want to delete this promotion?")) {
            $.ajax({
                url: '/HR/DeletePromotion',
                type: "POST",
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        }
    }
</script>
