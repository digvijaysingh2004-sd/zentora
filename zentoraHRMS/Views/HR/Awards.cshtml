@model IEnumerable<zentoraHRMS.Models.AwardModel>
@{
    ViewBag.Title = "Employee Awards";
}

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">Awards List</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title">Award Details</h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" data-bs-toggle="modal" data-bs-target="#AddAward">
                        <i class="me-1" data-lucide="plus"></i> Add Award
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Employee</th>
                                <th>Award Type</th>
                                <th>Gift</th>
                                <th>Cash Price</th>
                                <th>Award Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td>@c.EmployeeName</td>
                                    <td>@c.AwardType</td>
                                    <td>@c.Gift</td>
                                    <td>$@c.CashPrice</td>
                                    <td>@c.AwardDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <a onclick="UpdateAward(@c.AwardId)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeleteAward(@c.AwardId)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddAward Modal -->
    <div id="AddAward" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="AwardForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Add Award</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="EmployeeId" class="form-label">Employee <span class="text-danger">*</span></label>
                            <select id="EmployeeId" data-choices class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="AwardType" class="form-label">Award Type <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="AwardType" placeholder="e.g. Employee of the Month" required>
                        </div>
                        <div class="mb-3">
                            <label for="Gift" class="form-label">Gift</label>
                            <input type="text" class="form-control" id="Gift">
                        </div>
                        <div class="mb-3">
                            <label for="CashPrice" class="form-label">Cash Price</label>
                            <input type="number" class="form-control" id="CashPrice" value="0">
                        </div>
                        <div class="mb-3">
                            <label for="AwardDate" class="form-label">Award Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="AwardDate" required>
                        </div>
                        <div class="mb-3">
                            <label for="Description" class="form-label">Description</label>
                            <textarea class="form-control" id="Description" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- UpdateAward Modal -->
    <div id="UpdateAwardModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="UpdateAwardForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Update Award</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="update_id" />
                        <div class="mb-3">
                            <label for="uEmployeeId" class="form-label">Employee <span class="text-danger">*</span></label>
                            <select id="uEmployeeId" data-choices class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="uAwardType" class="form-label">Award Type <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="uAwardType" required>
                        </div>
                        <div class="mb-3">
                            <label for="uGift" class="form-label">Gift</label>
                            <input type="text" class="form-control" id="uGift">
                        </div>
                        <div class="mb-3">
                            <label for="uCashPrice" class="form-label">Cash Price</label>
                            <input type="number" class="form-control" id="uCashPrice">
                        </div>
                        <div class="mb-3">
                            <label for="uAwardDate" class="form-label">Award Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="uAwardDate" required>
                        </div>
                        <div class="mb-3">
                            <label for="uDescription" class="form-label">Description</label>
                            <textarea class="form-control" id="uDescription" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $.ajax({
            url: '/Staff/GetEmployeeList',
            type: 'GET',
            success: function (data) {
                var s = '<option value="" selected disabled>Select Employee</option>';
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].Id + '">' + data[i].FirstName + ' ' + data[i].LastName + '</option>';
                }
                $("#EmployeeId").html(s);
                $("#uEmployeeId").html(s);
            }
        });

        $("#AwardForm").on("submit", function (e) {
            e.preventDefault();
            if (!validateForm('AwardForm')) {
                return false;
            }
            var formData = {
                EmployeeId: $("#EmployeeId").val(),
                AwardType: $("#AwardType").val(),
                Gift: $("#Gift").val(),
                CashPrice: $("#CashPrice").val(),
                AwardDate: $("#AwardDate").val(),
                Description: $("#Description").val()
            };
            $.ajax({
                url: '/HR/SaveAward',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        $("#UpdateAwardForm").on("submit", function (e) {
            e.preventDefault();
            if (!validateForm('UpdateAwardForm')) {
                return false;
            }
            var formData = {
                AwardId: $("#update_id").val(),
                EmployeeId: $("#uEmployeeId").val(),
                AwardType: $("#uAwardType").val(),
                Gift: $("#uGift").val(),
                CashPrice: $("#uCashPrice").val(),
                AwardDate: $("#uAwardDate").val(),
                Description: $("#uDescription").val()
            };
            $.ajax({
                url: '/HR/UpdateAward',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });
    });

    function UpdateAward(id) {
        $.ajax({
            url: '/HR/GetAwardById',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                if (data) {
                    $("#update_id").val(data.AwardId);
                    $("#uEmployeeId").val(data.EmployeeId);
                    $("#uAwardType").val(data.AwardType);
                    $("#uGift").val(data.Gift);
                    $("#uCashPrice").val(data.CashPrice);
                    if (data.AwardDate) {
                        var date = new Date(parseInt(data.AwardDate.substr(6)));
                        var formattedDate = date.getFullYear() + '-' + ('0' + (date.getMonth() + 1)).slice(-2) + '-' + ('0' + date.getDate()).slice(-2);
                        $("#uAwardDate").val(formattedDate);
                    }
                    $("#uDescription").val(data.Description);
                    $("#UpdateAwardModal").modal("show");
                }
            }
        });
    }

    function DeleteAward(id) {
        if (confirm("Are you sure you want to delete this award?")) {
            $.ajax({
                url: '/HR/DeleteAward',
                type: "POST",
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        }
    }
</script>
