@model IEnumerable<zentoraHRMS.Models.AssetModel>
@{
    ViewBag.Title = "Asset Management";
}

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">Company Assets</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title">Asset Tracking</h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" data-bs-toggle="modal" data-bs-target="#AddAsset">
                        <i class="me-1" data-lucide="plus"></i> Add Asset
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Asset Code</th>
                                <th>Asset Name</th>
                                <th>Assigned Employee</th>
                                <th>Purchase Date</th>
                                <th>Warranty Date</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td>@c.AssetCode</td>
                                    <td>@c.AssetName</td>
                                    <td>@c.EmployeeName</td>
                                    <td>@(c.PurchaseDate.HasValue ? c.PurchaseDate.Value.ToString("yyyy-MM-dd") : "N/A")</td>
                                    <td>@(c.WarrantyDate.HasValue ? c.WarrantyDate.Value.ToString("yyyy-MM-dd") : "N/A")</td>
                                    <td>
                                        @if (c.Status == "Working") { <span class="badge bg-success-subtle text-success">Working</span> }
                                        else if (c.Status == "Under Repair") { <span class="badge bg-warning-subtle text-warning">Under Repair</span> }
                                        else { <span class="badge bg-danger-subtle text-danger">@c.Status</span> }
                                    </td>
                                    <td>
                                        <a onclick="UpdateAsset(@c.AssetId)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeleteAsset(@c.AssetId)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddAsset Modal -->
    <div id="AddAsset" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="AssetForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Add Asset</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="AssetCode" class="form-label">Asset Code <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="AssetCode" required>
                        </div>
                        <div class="mb-3">
                            <label for="AssetName" class="form-label">Asset Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="AssetName" required>
                        </div>
                        <div class="mb-3">
                            <label for="EmployeeId" class="form-label">Assign To</label>
                            <select id="EmployeeId" class="form-select"></select>
                        </div>
                        <div class="mb-3">
                            <label for="PurchaseDate" class="form-label">Purchase Date</label>
                            <input type="date" class="form-control" id="PurchaseDate">
                        </div>
                        <div class="mb-3">
                            <label for="WarrantyDate" class="form-label">Warranty Expiry</label>
                            <input type="date" class="form-control" id="WarrantyDate">
                        </div>
                        <div class="mb-3">
                            <label for="Status" class="form-label">Status <span class="text-danger">*</span></label>
                            <select id="Status" class="form-select" required>
                                <option value="Working" selected>Working</option>
                                <option value="Under Repair">Under Repair</option>
                                <option value="Damaged">Damaged</option>
                                <option value="Lost">Lost</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- UpdateAsset Modal -->
    <div id="UpdateAssetModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="UpdateAssetForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Update Asset</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="update_id" />
                        <div class="mb-3">
                            <label for="uAssetCode" class="form-label">Asset Code <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="uAssetCode" required>
                        </div>
                        <div class="mb-3">
                            <label for="uAssetName" class="form-label">Asset Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="uAssetName" required>
                        </div>
                        <div class="mb-3">
                            <label for="uEmployeeId" class="form-label">Assign To</label>
                            <select id="uEmployeeId" class="form-select"></select>
                        </div>
                        <div class="mb-3">
                            <label for="uPurchaseDate" class="form-label">Purchase Date</label>
                            <input type="date" class="form-control" id="uPurchaseDate">
                        </div>
                        <div class="mb-3">
                            <label for="uWarrantyDate" class="form-label">Warranty Expiry</label>
                            <input type="date" class="form-control" id="uWarrantyDate">
                        </div>
                        <div class="mb-3">
                            <label for="uStatus" class="form-label">Status <span class="text-danger">*</span></label>
                            <select id="uStatus" class="form-select" required>
                                <option value="Working">Working</option>
                                <option value="Under Repair">Under Repair</option>
                                <option value="Damaged">Damaged</option>
                                <option value="Lost">Lost</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $.ajax({
            url: '/Staff/GetEmployeeList',
            type: 'GET',
            success: function (data) {
                var s = '<option value="" selected>Unassigned</option>';
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].Id + '">' + data[i].FirstName + ' ' + data[i].LastName + '</option>';
                }
                $("#EmployeeId").html(s);
                $("#uEmployeeId").html(s);
            }
        });

        $("#AssetForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                AssetCode: $("#AssetCode").val(),
                AssetName: $("#AssetName").val(),
                EmployeeId: $("#EmployeeId").val() || null,
                PurchaseDate: $("#PurchaseDate").val() || null,
                WarrantyDate: $("#WarrantyDate").val() || null,
                Status: $("#Status").val()
            };
            $.ajax({
                url: '/HR/SaveAsset',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        $("#UpdateAssetForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                AssetId: $("#update_id").val(),
                AssetCode: $("#uAssetCode").val(),
                AssetName: $("#uAssetName").val(),
                EmployeeId: $("#uEmployeeId").val() || null,
                PurchaseDate: $("#uPurchaseDate").val() || null,
                WarrantyDate: $("#uWarrantyDate").val() || null,
                Status: $("#uStatus").val()
            };
            $.ajax({
                url: '/HR/UpdateAsset',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });
    });

    function UpdateAsset(id) {
        $.ajax({
            url: '/HR/GetAssetById',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                if (data) {
                    $("#update_id").val(data.AssetId);
                    $("#uAssetCode").val(data.AssetCode);
                    $("#uAssetName").val(data.AssetName);
                    $("#uEmployeeId").val(data.EmployeeId || "");
                    if (data.PurchaseDate) {
                        var date = new Date(parseInt(data.PurchaseDate.substr(6)));
                        var formattedDate = date.getFullYear() + '-' + ('0' + (date.getMonth() + 1)).slice(-2) + '-' + ('0' + date.getDate()).slice(-2);
                        $("#uPurchaseDate").val(formattedDate);
                    } else {
                        $("#uPurchaseDate").val("");
                    }
                    if (data.WarrantyDate) {
                        var date = new Date(parseInt(data.WarrantyDate.substr(6)));
                        var formattedDate = date.getFullYear() + '-' + ('0' + (date.getMonth() + 1)).slice(-2) + '-' + ('0' + date.getDate()).slice(-2);
                        $("#uWarrantyDate").val(formattedDate);
                    } else {
                        $("#uWarrantyDate").val("");
                    }
                    $("#uStatus").val(data.Status);
                    $("#UpdateAssetModal").modal("show");
                }
            }
        });
    }

    function DeleteAsset(id) {
        if (confirm("Are you sure you want to delete this asset?")) {
            $.ajax({
                url: '/HR/DeleteAsset',
                type: "POST",
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        }
    }
</script>
