@model IEnumerable<zentoraHRMS.Models.ModuleActionModel>
@{
    ViewBag.Title = "Module Actions";
}

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">Module Actions</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title">Module Action Details</h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" data-bs-toggle="modal" data-bs-target="#AddAction">
                        <i class="me-1" data-lucide="plus"></i> Add Module Action
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Action ID</th>
                                <th>Action Name</th>
                                <th>Action Code</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td>@c.ActionId</td>
                                    <td>@c.ActionName</td>
                                    <td>@c.ActionCode</td>
                                    <td>
                                        <a onclick="UpdateAction(@c.ActionId)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeleteAction(@c.ActionId)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddAction Modal -->
    <div id="AddAction" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="ActionForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Add Module Action</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="ActionName" class="form-label">Action Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="ActionName" required>
                        </div>
                        <div class="mb-3">
                            <label for="ActionCode" class="form-label">Action Code <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="ActionCode" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- UpdateAction Modal -->
    <div id="UpdateActionModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="UpdateActionForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Update Module Action</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="update_id" />
                        <div class="mb-3">
                            <label for="uActionName" class="form-label">Action Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="uActionName" required>
                        </div>
                        <div class="mb-3">
                            <label for="uActionCode" class="form-label">Action Code <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="uActionCode" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#ActionForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                ActionName: $("#ActionName").val(),
                ActionCode: $("#ActionCode").val()
            };
            $.ajax({
                url: '/Modules/SaveModuleAction',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        $("#UpdateActionForm").on("submit", function (e) {
            e.preventDefault();
            var formData = {
                ActionId: $("#update_id").val(),
                ActionName: $("#uActionName").val(),
                ActionCode: $("#uActionCode").val()
            };
            $.ajax({
                url: '/Modules/UpdateModuleAction',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });
    });

    function UpdateAction(id) {
        $.ajax({
            url: '/Modules/GetModuleActionById',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                if (data) {
                    $("#update_id").val(data.ActionId);
                    $("#uActionName").val(data.ActionName);
                    $("#uActionCode").val(data.ActionCode);
                    $("#UpdateActionModal").modal("show");
                }
            }
        });
    }

    function DeleteAction(id) {
        if (confirm("Are you sure you want to delete this module action?")) {
            $.ajax({
                url: '/Modules/DeleteModuleAction',
                type: "POST",
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        }
    }
</script>
