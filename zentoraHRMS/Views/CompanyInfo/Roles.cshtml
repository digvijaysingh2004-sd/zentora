@model zentoraHRMS.Models.RolePageViewModel
@{
    ViewBag.Title = "Roles";
}

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="#" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">
                Roles Management
            </h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title"> Role Details </h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" data-bs-toggle="modal" data-bs-target="#AddRoleModal">
                        <i class="me-1" data-lucide="plus"></i> Add Role
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Role Code</th>
                                <th>Role Name</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.RolesList != null)
                            {
                                foreach (var role in Model.RolesList)
                                {
                                    <tr>
                                        <td class="fs-sm" style="width: 1%;"></td>
                                        <td>@role.RoleId</td>
                                        <td class="fw-medium">@role.RoleName</td>
                                        <td>@role.RoleDescription</td>
                                        <td>
                                            @if (role.IsActive)
                                            {
                                                <span class="badge badge-label badge-soft-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-label badge-soft-danger">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <a onclick="UpdateRole(@role.Id)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                            <a onclick="DeleteRole(@role.Id)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div id="AddRoleModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <form id="RoleForm" class="needs-validation" novalidate>
                    <div class="modal-header">
                        <h4 class="modal-title"> Add Role Details </h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <ul class="nav nav-pills mb-3 justify-content-center" id="RoleTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="btn btn-sm btn-soft-secondary me-1 mb-1 rounded-1 active" data-bs-toggle="tab" data-bs-target="#RoleInfo" type="button" role="tab"> Role Info </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="btn btn-sm btn-soft-secondary me-1 mb-1 rounded-1" data-bs-toggle="tab" data-bs-target="#RolePermissions" type="button" role="tab"> Permissions </button>
                            </li>
                        </ul>

                        <div class="tab-content mt-3">
                            <div class="tab-pane fade show active" id="RoleInfo" role="tabpanel">
                                <div class="row">
                                    <div class="col-md-4 mt-3">
                                        <label class="form-label">Role Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="role_name" placeholder="e.g. Employee" required>
                                    </div>
                                    <div class="col-md-4 mt-3">
                                        <label class="form-label">Role Code <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="role_code" placeholder="e.g. EMP-01" required>
                                    </div>
                                    <div class="col-md-4 mt-3">
                                        <label class="form-label">Description</label>
                                        <input type="text" class="form-control" id="role_description" placeholder="Optional brief description">
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="RolePermissions" role="tabpanel">
                                <div class="d-flex justify-content-end mb-2">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="full-access-add">
                                        <label class="form-check-label fw-bold text-primary" for="full-access-add">Grant Full Access</label>
                                    </div>
                                </div>

                                <div class="table-responsive" style="max-height: 350px; overflow-y: auto;">
                                    <table class="table table-bordered table-sm align-middle mb-0" id="add-permissions-table">
                                        <thead class="table-light text-center position-sticky top-0 z-1">
                                            <tr>
                                                <th class="text-start bg-light">Module / Submodule</th>
                                                <th style="width: 12%;" class="bg-light">View</th>
                                                <th style="width: 12%;" class="bg-light">Add</th>
                                                <th style="width: 12%;" class="bg-light">Edit</th>
                                                <th style="width: 12%;" class="bg-light">Delete</th>
                                                <th style="width: 12%;" class="bg-soft-primary">All</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model != null && Model.Modules != null && Model.Modules.ParentModules != null)
                                            {
                                                foreach (var parent in Model.Modules.ParentModules)
                                                {
                                                    if (parent.Children == null || !parent.Children.Any())
                                                    {
                                                        <tr>
                                                            <td class="fw-medium">@parent.ModuleName</td>
                                                            <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="p_@parent.ParentModuleId" data-action="view"></td>
                                                            <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="p_@parent.ParentModuleId" data-action="add"></td>
                                                            <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="p_@parent.ParentModuleId" data-action="edit"></td>
                                                            <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="p_@parent.ParentModuleId" data-action="delete"></td>
                                                            <td class="text-center bg-soft-primary"><input class="form-check-input select-all-row perm-check" type="checkbox"></td>
                                                        </tr>
                                                    }
                                                    else
                                                    {
                                                        <tr>
                                                            <td colspan="6" class="bg-light fw-bold text-uppercase fs-xxs">@parent.ModuleName</td>
                                                        </tr>
                                                        foreach (var child in parent.Children)
                                                        {
                                                            if (child.SubChildren == null || !child.SubChildren.Any())
                                                            {
                                                                <tr>
                                                                    <td class="ps-4"><i data-lucide="corner-down-right" class="fs-xs me-2 text-muted"></i> @child.ModuleName</td>
                                                                    <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="c_@child.ChildModuleId" data-action="view"></td>
                                                                    <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="c_@child.ChildModuleId" data-action="add"></td>
                                                                    <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="c_@child.ChildModuleId" data-action="edit"></td>
                                                                    <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="c_@child.ChildModuleId" data-action="delete"></td>
                                                                    <td class="text-center bg-soft-primary"><input class="form-check-input select-all-row perm-check" type="checkbox"></td>
                                                                </tr>
                                                            }
                                                            else
                                                            {
                                                                <tr>
                                                                    <td colspan="6" class="bg-light fw-bold fs-xxs ps-4">@child.ModuleName</td>
                                                                </tr>
                                                                foreach (var sub in child.SubChildren)
                                                                {
                                                                    <tr>
                                                                        <td class="ps-5"><i data-lucide="corner-down-right" class="fs-xs me-2 text-muted"></i> @sub.ModuleName</td>
                                                                        <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="s_@sub.SubChildModuleId" data-action="view"></td>
                                                                        <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="s_@sub.SubChildModuleId" data-action="add"></td>
                                                                        <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="s_@sub.SubChildModuleId" data-action="edit"></td>
                                                                        <td class="text-center"><input class="form-check-input perm-check" type="checkbox" data-module-id="s_@sub.SubChildModuleId" data-action="delete"></td>
                                                                        <td class="text-center bg-soft-primary"><input class="form-check-input select-all-row perm-check" type="checkbox"></td>
                                                                    </tr>
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="reset" id="reset-add-form" class="btn btn-soft-warning"> Reset </button>
                        <button type="submit" class="btn btn-soft-primary"> Save Role </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="UpdateRoleModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <form id="UpdateRoleForm" class="needs-validation" novalidate>
                    <input type="hidden" id="u_id" />
                    <div class="modal-header">
                        <h4 class="modal-title"> Update Role Details </h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <ul class="nav nav-pills mb-3 justify-content-center" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="btn btn-sm btn-soft-secondary me-1 mb-1 rounded-1 active" data-bs-toggle="tab" data-bs-target="#UpdateRoleInfo" type="button" role="tab"> Role Info </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="btn btn-sm btn-soft-secondary me-1 mb-1 rounded-1" data-bs-toggle="tab" data-bs-target="#UpdateRolePermissions" type="button" role="tab"> Permissions </button>
                            </li>
                        </ul>

                        <div class="tab-content mt-3">
                            <div class="tab-pane fade show active" id="UpdateRoleInfo" role="tabpanel">
                                <div class="row">
                                    <div class="col-md-4 mt-3">
                                        <label class="form-label">Role Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="u_role_name" required>
                                    </div>
                                    <div class="col-md-4 mt-3">
                                        <label class="form-label">Role Code <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="u_role_code" required>
                                    </div>
                                    <div class="col-md-4 mt-3">
                                        <label class="form-label">Description</label>
                                        <input type="text" class="form-control" id="u_role_description">
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="UpdateRolePermissions" role="tabpanel">
                                <div class="d-flex justify-content-end mb-2">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="full-access-update">
                                        <label class="form-check-label fw-bold text-primary" for="full-access-update">Grant Full Access</label>
                                    </div>
                                </div>

                                <div class="table-responsive" style="max-height: 350px; overflow-y: auto;">
                                    <table class="table table-bordered table-sm align-middle mb-0" id="update-permissions-table">
                                        <thead class="table-light text-center position-sticky top-0 z-1">
                                            <tr>
                                                <th class="text-start bg-light">Module / Submodule</th>
                                                <th style="width: 12%;" class="bg-light">View</th>
                                                <th style="width: 12%;" class="bg-light">Add</th>
                                                <th style="width: 12%;" class="bg-light">Edit</th>
                                                <th style="width: 12%;" class="bg-light">Delete</th>
                                                <th style="width: 12%;" class="bg-soft-primary">All</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model != null && Model.Modules != null && Model.Modules.ParentModules != null)
                                            {
                                                foreach (var parent in Model.Modules.ParentModules)
                                                {
                                                    if (parent.Children == null || !parent.Children.Any())
                                                    {
                                                        <tr>
                                                            <td class="fw-medium">@parent.ModuleName</td>
                                                            <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="p_@parent.ParentModuleId" data-action="view"></td>
                                                            <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="p_@parent.ParentModuleId" data-action="add"></td>
                                                            <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="p_@parent.ParentModuleId" data-action="edit"></td>
                                                            <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="p_@parent.ParentModuleId" data-action="delete"></td>
                                                            <td class="text-center bg-soft-primary"><input class="form-check-input select-all-row u-perm-check" type="checkbox"></td>
                                                        </tr>
                                                    }
                                                    else
                                                    {
                                                        <tr>
                                                            <td colspan="6" class="bg-light fw-bold text-uppercase fs-xxs">@parent.ModuleName</td>
                                                        </tr>
                                                        foreach (var child in parent.Children)
                                                        {
                                                            if (child.SubChildren == null || !child.SubChildren.Any())
                                                            {
                                                                <tr>
                                                                    <td class="ps-4"><i data-lucide="corner-down-right" class="fs-xs me-2 text-muted"></i> @child.ModuleName</td>
                                                                    <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="c_@child.ChildModuleId" data-action="view"></td>
                                                                    <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="c_@child.ChildModuleId" data-action="add"></td>
                                                                    <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="c_@child.ChildModuleId" data-action="edit"></td>
                                                                    <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="c_@child.ChildModuleId" data-action="delete"></td>
                                                                    <td class="text-center bg-soft-primary"><input class="form-check-input select-all-row u-perm-check" type="checkbox"></td>
                                                                </tr>
                                                            }
                                                            else
                                                            {
                                                                <tr>
                                                                    <td colspan="6" class="bg-light fw-bold fs-xxs ps-4">@child.ModuleName</td>
                                                                </tr>
                                                                foreach (var sub in child.SubChildren)
                                                                {
                                                                    <tr>
                                                                        <td class="ps-5"><i data-lucide="corner-down-right" class="fs-xs me-2 text-muted"></i> @sub.ModuleName</td>
                                                                        <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="s_@sub.SubChildModuleId" data-action="view"></td>
                                                                        <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="s_@sub.SubChildModuleId" data-action="add"></td>
                                                                        <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="s_@sub.SubChildModuleId" data-action="edit"></td>
                                                                        <td class="text-center"><input class="form-check-input u-perm-check" type="checkbox" data-module-id="s_@sub.SubChildModuleId" data-action="delete"></td>
                                                                        <td class="text-center bg-soft-primary"><input class="form-check-input select-all-row u-perm-check" type="checkbox"></td>
                                                                    </tr>
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-soft-secondary" data-bs-dismiss="modal"> Cancel </button>
                        <button type="submit" class="btn btn-soft-primary"> Update Role </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {

        // ==========================================
        // UI SYNCHRONIZATION HELPERS
        // ==========================================
        function syncPermissionCheckboxes(tableId, globalToggleId) {
            var totalIndividualBoxes = 0;
            var totalCheckedIndividualBoxes = 0;

            $(tableId + ' tbody tr').each(function () {
                var $row = $(this);
                var $individualCheckboxes = $row.find('input[type="checkbox"]').not('.select-all-row');

                if ($individualCheckboxes.length > 0) {
                    var checkedCount = $individualCheckboxes.filter(':checked').length;
                    var allChecked = (checkedCount === $individualCheckboxes.length);

                    $row.find('.select-all-row').prop('checked', allChecked);

                    totalIndividualBoxes += $individualCheckboxes.length;
                    totalCheckedIndividualBoxes += checkedCount;
                }
            });

            var globalChecked = (totalIndividualBoxes > 0 && totalIndividualBoxes === totalCheckedIndividualBoxes);
            $(globalToggleId).prop('checked', globalChecked);
        }

        // 1. When an individual box is clicked, sync the row's "All" and the "Global" toggle
        $(document).on('change', '#add-permissions-table input[type="checkbox"]:not(.select-all-row)', function () {
            syncPermissionCheckboxes('#add-permissions-table', '#full-access-add');
        });
        $(document).on('change', '#update-permissions-table input[type="checkbox"]:not(.select-all-row)', function () {
            syncPermissionCheckboxes('#update-permissions-table', '#full-access-update');
        });

        // 2. When the row's "All" box is clicked, check all in row, then sync the "Global" toggle
        $(document).on('change', '.select-all-row', function () {
            $(this).closest('tr').find('input[type="checkbox"]').not(this).prop('checked', this.checked);
            var tableId = '#' + $(this).closest('table').attr('id');
            var globalToggleId = tableId === '#add-permissions-table' ? '#full-access-add' : '#full-access-update';
            syncPermissionCheckboxes(tableId, globalToggleId);
        });

        // 3. When "Grant Full Access" is clicked, check/uncheck everything
        $('#full-access-add').on('change', function () {
            $('#add-permissions-table input[type="checkbox"]').prop('checked', this.checked);
        });
        $('#full-access-update').on('change', function () {
            $('#update-permissions-table input[type="checkbox"]').prop('checked', this.checked);
        });

        // 4. CLEAR ON CLOSE (Add Modal Only)
        $('#AddRoleModal').on('hidden.bs.modal', function () {
            $('#RoleForm')[0].reset();
            $('#full-access-add').prop('checked', false);
            var triggerEl = document.querySelector('#RoleTab button[data-bs-target="#RoleInfo"]');
            if (triggerEl) {
                var tab = new bootstrap.Tab(triggerEl);
                tab.show();
            }
        });

        // Re-initialize lucide icons
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }

        // ==========================================
        // AJAX FORM SUBMISSIONS
        // ==========================================

        // ADD ROLE
        $("#RoleForm").on("submit", function (e) {
            e.preventDefault();

            var permissionsArray = [];
            $('#add-permissions-table .perm-check:checked').not('.select-all-row').each(function () {
                var fullModuleId = $(this).data('module-id');
                if (fullModuleId) {
                    var parts = fullModuleId.split('_');
                    permissionsArray.push({
                        ModuleLevel: parts[0],
                        ModuleId: parseInt(parts[1]),
                        ActionCode: $(this).data('action')
                    });
                }
            });

            var formData = {
                RoleName: $("#role_name").val(),
                RoleId: $("#role_code").val(),
                RoleDescription: $("#role_description").val(),
                Permissions: permissionsArray
            };

            $.ajax({
                url: '/CompanyInfo/SaveRole',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        $('#AddRoleModal').modal('hide');
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        // UPDATE ROLE
        $("#UpdateRoleForm").on("submit", function (e) {
            e.preventDefault();

            var permissionsArray = [];
            $('#update-permissions-table .u-perm-check:checked').not('.select-all-row').each(function () {
                var fullModuleId = $(this).data('module-id');
                if (fullModuleId) {
                    var parts = fullModuleId.split('_');
                    permissionsArray.push({
                        ModuleLevel: parts[0],
                        ModuleId: parseInt(parts[1]) || 0,
                        ActionCode: $(this).data('action') || 'view'
                    });
                }
            });

            var roleIdInt = parseInt($("#u_id").val()) || 0;

            var formData = {
                Id: roleIdInt,
                RoleName: $("#u_role_name").val() || "",
                RoleId: $("#u_role_code").val() || "",
                RoleDescription: $("#u_role_description").val() || "",
                Permissions: permissionsArray
            };

            if (roleIdInt === 0) {
                alert("Error: Role ID is missing. Please close the modal and try clicking Edit again.");
                return;
            }

            $.ajax({
                url: '/CompanyInfo/UpdateRole',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        $('#UpdateRoleModal').modal('hide');
                        location.reload();
                    } else {
                        alert("Database Error: " + res.message);
                    }
                },
                error: function (xhr) {
                    console.error("Server Error:", xhr.responseText);
                    alert("A critical server error occurred. Did you remember to update Web.config?");
                }
            });
        });
    });

    // ==========================================
    // ROW ACTIONS (Edit / Delete)
    // ==========================================

    function UpdateRole(id) {
        $.get('/CompanyInfo/GetRoleDetails', { id: id }, function (data) {
            if (data.error) {
                alert("Error loading data: " + data.error);
                return;
            }

            $("#u_id").val(data.Id);
            $("#u_role_name").val(data.RoleName);
            $("#u_role_code").val(data.RoleId);
            $("#u_role_description").val(data.RoleDescription);

            // Wipe all checkboxes clean initially
            $('#update-permissions-table input[type="checkbox"]').prop('checked', false);
            $('#full-access-update').prop('checked', false);

            // Check the specific individual boxes returned from DB
            if (data.Permissions && data.Permissions.length > 0) {
                data.Permissions.forEach(function (p) {
                    var levelPrefix = p.ModuleLevel + '_' + p.ModuleId;
                    $('#update-permissions-table .u-perm-check[data-module-id="' + levelPrefix + '"][data-action="' + p.ActionCode + '"]').prop('checked', true);
                });
            }

            // Run the sync function so the "All" boxes auto-check if necessary!
            if (typeof syncPermissionCheckboxes !== 'undefined') {
                syncPermissionCheckboxes('#update-permissions-table', '#full-access-update');
            } else {
                // Fallback manual sync
                var totalBoxes = 0;
                var checkedBoxes = 0;
                $('#update-permissions-table tbody tr').each(function () {
                    var $row = $(this);
                    var $indivBoxes = $row.find('input[type="checkbox"]').not('.select-all-row');
                    if ($indivBoxes.length > 0) {
                        var count = $indivBoxes.filter(':checked').length;
                        $row.find('.select-all-row').prop('checked', count === $indivBoxes.length);
                        totalBoxes += $indivBoxes.length;
                        checkedBoxes += count;
                    }
                });
                $('#full-access-update').prop('checked', (totalBoxes > 0 && totalBoxes === checkedBoxes));
            }

            $('#UpdateRoleModal').modal('show');
        });
    }

    function DeleteRole(id) {
        if (confirm("Are you sure you want to delete this role?")) {
            $.post('/CompanyInfo/DeleteRole', { id: id }, function (res) {
                if (res.success) {
                    location.reload();
                } else {
                    alert("Error deleting role: " + res.message);
                }
            });
        }
    }
</script>