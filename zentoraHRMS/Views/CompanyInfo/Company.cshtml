@model IEnumerable<zentoraHRMS.Models.CompanyModel>
@{
    ViewBag.Title = "Company";
}

<div class="container-fluid">

    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">
                Company
            </h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-1">
                <div class="card-header justify-content-between">
                    <h5 class="card-title"> Company Details </h5>
                    <button type="button" class="btn btn-sm btn-soft-primary rounded-1" data-bs-toggle="modal" data-bs-target="#AddCompany"><i class="me-1" data-lucide="plus"></i> Add Company </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Company Name</th>
                                <th>Company Code</th>
                                <th>Company Type</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Industry Type</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td>@c.CompanyName</td>
                                    <td>@c.CompanyCode</td>
                                    <td>@c.CompanyType</td>
                                    <td>@c.PrimaryEmail</td>
                                    <td>@c.PrimaryPhone</td>
                                    <td>@c.IndustryType</td>
                                    <td><span class="badge badge-label badge-soft-success">Active</span></td>
                                    <td>
                                        <a onclick="UpdateCompany(@c.CompanyId)" data-bs-toggle="modal" data-bs-target="#UpdateCompany" class="btn btn-sm btn-soft-info" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeleteCompany(@c.CompanyId)" class="btn btn-sm btn-soft-danger" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddCompany Start -->
    <div id="AddCompany" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="AddCompany" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <form id="companyForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title" id="fullWidthModalLabel">Add Company Details</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <!-- Button-style Tabs -->
                        <ul class="nav nav-pills mb-3 justify-content-center" id="companyTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="btn btn-sm btn-soft-secondary me-1 mb-1 rounded-1 active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button" role="tab"> General Info </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="btn btn-sm btn-soft-secondary me-1 mb-1 rounded-1" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact" type="button" role="tab"> Contact Info </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="btn btn-sm btn-soft-secondary me-1 mb-1 rounded-1" id="hr-tab" data-bs-toggle="tab" data-bs-target="#hr" type="button" role="tab"> HR Info </button>
                            </li>
