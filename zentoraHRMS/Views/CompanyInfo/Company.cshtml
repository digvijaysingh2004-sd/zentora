                                    </div>
                                    <div class="col-md-4 mt-3">
                                        <label for="ti" class="form-label">Tax Id <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="ti" required>
                                        <div class="invalid-feedback">Please provide a valid Tax Id.</div>
                                    </div>
                                </div>
                            </div>
                            <!-- Contact Info -->
