                                        <input type="text" class="form-control" id="note" required>
                                        <div class="invalid-feedback">Please provide a valid Note.</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
