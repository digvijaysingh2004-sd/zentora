                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="btn btn-sm btn-soft-secondary me-1 mb-1 rounded-1" id="other-tab" data-bs-toggle="tab" data-bs-target="#other" type="button" role="tab"> Other Info </button>
