                                        <input type="text" class="form-control" id="tw" required>
                                        <div class="invalid-feedback">Please provide a valid Twitter Url.</div>
                                    </div>
                                    <div class="col-md-4 mt-3">
                                        <label for="fb" class="form-label">Facebook Url <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="fb" required>
                                        <div class="invalid-feedback">Please provide a valid Facebook Url.</div>
                                    </div>
                                    <div class="col-md-4 mt-3">
                                        <label for="ig" class="form-label">Instagram Url <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="ig" required>
                                        <div class="invalid-feedback">Please provide a valid Instagram Url.</div>
                                    </div>
                                </div>
                            </div>
                            <!-- Other Info -->
                            <div class="tab-pane fade" id="other" role="tabpanel">
                                <div class="row">
                                    <div class="col-md-4 mt-3">
                                        <label for="pci" class="form-label">Parent CompanyId <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="pci" required>
                                        <div class="invalid-feedback">Please provide a valid Parent CompanyId.</div>
                                    </div>
                                    <div class="col-md-4 mt-3">
                                        <label for="noe" class="form-label">Number of Employees <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="noe" required>
                                        <div class="invalid-feedback">Please provide a valid Number of Employees.</div>
                                    </div>
                                    <div class="col-md-4 mt-3">
