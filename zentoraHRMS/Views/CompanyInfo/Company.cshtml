<script>
    $(document).ready(function () {
        $("#companyForm").on("submit", function (e) {
            e.preventDefault();

            var form = this;

            if (!form.checkValidity()) {
                e.stopPropagation();
                $(form).addClass("was-validated");
                return;
            }

            var formData = {
                CompanyName: $("#cn").val(),
                CompanyCode: $("#cc").val(),
                RegistrationNumber: $("#rn").val(),
                CompanyType: $("#ct").val(),
                IndustryType: $("#it").val(),
                TaxId: $("#ti").val(),
                PrimaryEmail: $("#pe").val(),
                PrimaryPhone: $("#pp").val(),
                SecondaryPhone: $("#sp").val(),
                AddressLine1: $("#al1").val(),
                AddressLine2: $("#al2").val(),
                City: $("#cy").val(),
                State: $("#st").val(),
                Country: $("#cty").val(),
                ZipCode: $("#zc").val(),
                WorkingDaysPerWeek: $("#wdpw").val(),
                PrimaryHRName: $("#phrcn").val(),
                PrimaryHREmail: $("#phrce").val(),
                PrimaryHRPhone: $("#phrcp").val(),
                DefaultCurrency: $("#dc").val(),
                DefaultTimeZone: $("#dtz").val(),
                FinancialYearStart: $("#fys").val(),
                FinancialYearEnd: $("#fye").val(),
                PayrollCycle: $("#pc").val(),
                DefaultLeavePolicy: $("#dlp").val(),
                ShiftTimings: $("#shift").val(),
                LogoUrl: $("#lu").val(),
                TagLine: $("#tl").val(),
                BrandingColor: $("#bc").val(),
                Website: $("#ws").val(),
                LinkedInUrl: $("#ln").val(),
                TwitterUrl: $("#tw").val(),
                FacebookUrl: $("#fb").val(),
                InstagramUrl: $("#ig").val(),
                ParentCompanyId: $("#pci").val(),
                NumberOfEmployees: $("#noe").val(),
                Certifications: $("#cert").val(),
                InsuranceDetails: $("#id").val(),
                Note: $("#note").val()
            };

            $.ajax({
                url: '@Url.Action("SaveCompany", "CompanyInfo")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function () {
                    location.reload();
                },
                error: function () {
                    alert("Error saving company details.");
                }
            });
        });

        $("#UpdatecompanyForm").on("submit", function (e) {
            e.preventDefault();

            var form = this;
            if (!form.checkValidity()) {
                e.stopPropagation();
                $(form).addClass("was-validated");
                return;
            }

            var formData = {
                CompanyId: $("#companyId").val(),
                CompanyName: $("#ucn").val(),
                CompanyCode: $("#ucc").val(),
                RegistrationNumber: $("#urn").val(),
                CompanyType: $("#uct").val(),
                IndustryType: $("#uit").val(),
                TaxId: $("#uti").val(),
                PrimaryEmail: $("#upe").val(),
                PrimaryPhone: $("#upp").val(),
                SecondaryPhone: $("#usp").val(),
                AddressLine1: $("#ual1").val(),
                AddressLine2: $("#ual2").val(),
                City: $("#ucy").val(),
                State: $("#ustate").val(),
                Country: $("#ucty").val(),
                ZipCode: $("#uzc").val(),
                WorkingDaysPerWeek: $("#uwdpw").val(),
                PrimaryHRName: $("#uphrcn").val(),
                PrimaryHREmail: $("#uphrce").val(),
                PrimaryHRPhone: $("#uphrcp").val(),
                DefaultCurrency: $("#udc").val(),
                DefaultTimeZone: $("#udtz").val(),
                FinancialYearStart: $("#ufys").val(),
                FinancialYearEnd: $("#ufye").val(),
                PayrollCycle: $("#upc").val(),
                DefaultLeavePolicy: $("#udlp").val(),
                ShiftTimings: $("#ushift").val(),
                LogoUrl: $("#ulu").val(),
                TagLine: $("#utl").val(),
                BrandingColor: $("#ubc").val(),
                Website: $("#uws").val(),
                LinkedInUrl: $("#uln").val(),
                TwitterUrl: $("#utw").val(),
                FacebookUrl: $("#ufb").val(),
                InstagramUrl: $("#uig").val(),
                ParentCompanyId: $("#upci").val(),
                NumberOfEmployees: $("#unoe").val(),
                Certifications: $("#ucert").val(),
                InsuranceDetails: $("#uid").val(),
                Note: $("#unote").val()
            };
            console.log(formData);
            $.ajax({
                url: '@Url.Action("UpdateCompany", "CompanyInfo")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function () {
                    location.reload();
                },
                error: function () {
                    alert("Error updating company details.");
                }
            });
        });
    });

    function UpdateCompany(id) {
        $.ajax({
            url: '@Url.Action("GetCompanyById", "CompanyInfo")',
            type: "GET",
            data: { id: id },
            success: function (data) {
                if (data) {
                    // Fill modal fields
                    $("#companyId").val(data.CompanyId);
                    $("#ucn").val(data.CompanyName);
                    $("#ucc").val(data.CompanyCode);
                    $("#urn").val(data.RegistrationNumber);
                    $("#uct").val(data.CompanyType);
                    $("#uit").val(data.IndustryType);
                    $("#uti").val(data.TaxId);
                    $("#upe").val(data.PrimaryEmail);
                    $("#upp").val(data.PrimaryPhone);
                    $("#usp").val(data.SecondaryPhone);
                    $("#ual1").val(data.AddressLine1);
                    $("#ual2").val(data.AddressLine2);
                    $("#ucy").val(data.City);
                    $("#ustate").val(data.State);
                    $("#ucty").val(data.Country);
                    $("#uzc").val(data.ZipCode);
                    $("#uwdpw").val(data.WorkingDaysPerWeek);
                    $("#uphrcn").val(data.PrimaryHRName);
                    $("#uphrce").val(data.PrimaryHREmail);
                    $("#uphrcp").val(data.PrimaryHRPhone);
                    $("#udc").val(data.DefaultCurrency);
                    $("#udtz").val(data.DefaultTimeZone);
                    $("#ufys").val(data.FinancialYearStart);
                    $("#ufye").val(data.FinancialYearEnd);
                    $("#upc").val(data.PayrollCycle);
                    $("#udlp").val(data.DefaultLeavePolicy);
                    $("#ushift").val(data.ShiftTimings);
                    $("#ulu").val(data.LogoUrl);
                    $("#utl").val(data.TagLine);
                    $("#ubc").val(data.BrandingColor);
                    $("#uws").val(data.Website);
                    $("#uln").val(data.LinkedInUrl);
                    $("#utw").val(data.TwitterUrl);
                    $("#ufb").val(data.FacebookUrl);
                    $("#uig").val(data.InstagramUrl);
                    $("#upci").val(data.ParentCompanyId);
                    $("#unoe").val(data.NumberOfEmployees);
                    $("#ucert").val(data.Certifications);
                    $("#uid").val(data.InsuranceDetails);
                    $("#unote").val(data.Note);

                    // Show modal
                    $("#UpdateCompany").modal("show");
                }
            },
            error: function () {
                alert("Error fetching company details.");
            }
        });
    }

    function DeleteCompany(id) {
        $.ajax({
            url: '@Url.Action("DeleteCompany", "CompanyInfo")',
            type: "POST",
            data: { companyId: id },
            success: function (response) {
                if (response.success) {
                    location.reload();
                } else {
                    alert.error("Error: " + response.message);
                }
            },
            error: function (xhr, status, error) {
                console.error("AJAX Error:", xhr.responseText);
                alert.error("AJAX Error: " + error);
            }
        });
    }

</script>
