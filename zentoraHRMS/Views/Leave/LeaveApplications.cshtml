@model IEnumerable<zentoraHRMS.Models.LeaveApplicationModel>
@{
    ViewBag.Title = "Leave Applications";
}

<div class="container-fluid">
    <div class="row justify-content-center py-5">
        <div class="col-xxl-5 col-xl-7 text-center">
            <a href="@Url.Action("Index","Home")" class="badge badge-default fw-normal shadow px-2 py-1 mb-2 fst-italic fs-xxs">
                <i data-lucide="square-check" class="fs-sm me-1"></i> DashBoard
            </a>
            <h3 class="fw-bold">Leave Applications</h3>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xxl-12">
            <div class="card rounded-2">
                <div class="card-header justify-content-between">
                    <h5 class="card-title">Leave Request List</h5>
                    <button type="button" class="btn btn-sm btn-soft-primary" data-bs-toggle="modal" data-bs-target="#AddLeave">
                        <i class="me-1" data-lucide="plus"></i> Apply For Leave
                    </button>
                </div>

                <div class="card-body">
                    <table id="checkbox-select-data" class="table table-striped dt-responsive checkbox-select-datatable align-middle mb-0">
                        <thead class="thead-sm text-uppercase fs-xxs">
                            <tr>
                                <th class="fs-sm" style="width: 1%;"></th>
                                <th>Employee</th>
                                <th>Leave Category</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Reason</th>
                                <th>Status</th>
                                <th>Applied Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fs-sm" style="width: 1%;"></td>
                                    <td>@c.EmployeeName</td>
                                    <td>@c.LeaveCategoryName</td>
                                    <td>@c.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@c.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>@c.Reason</td>
                                    <td>
                                        @if (c.Status == "Approved") { <span class="badge bg-success">Approved</span> }
                                        else if (c.Status == "Pending") { <span class="badge bg-warning text-dark">Pending</span> }
                                        else { <span class="badge bg-danger">Rejected</span> }
                                    </td>
                                    <td>@c.AppliedDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <a onclick="UpdateLeave(@c.LeaveApplicationId)" class="btn btn-sm btn-soft-info mt-1" title="Update"><i data-lucide="square-pen"></i></a>
                                        <a onclick="DeleteLeave(@c.LeaveApplicationId)" class="btn btn-sm btn-soft-danger mt-1" title="Delete"><i data-lucide="trash-2"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AddLeave Modal -->
    <div id="AddLeave" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="LeaveForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Apply For Leave</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="EmployeeId" class="form-label">Employee <span class="text-danger">*</span></label>
                            <select id="EmployeeId" data-choices class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="LeaveCategoryId" class="form-label">Leave Category <span class="text-danger">*</span></label>
                            <select id="LeaveCategoryId" data-choices class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="StartDate" class="form-label">Start Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="StartDate" required>
                        </div>
                        <div class="mb-3">
                            <label for="EndDate" class="form-label">End Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="EndDate" required>
                        </div>
                        <div class="mb-3">
                            <label for="Reason" class="form-label">Reason</label>
                            <textarea class="form-control" id="Reason" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="Status" class="form-label">Status <span class="text-danger">*</span></label>
                            <select id="Status" data-choices class="form-select" required>
                                <option value="Pending" selected>Pending</option>
                                <option value="Approved">Approved</option>
                                <option value="Rejected">Rejected</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- UpdateLeave Modal -->
    <div id="UpdateLeaveModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="UpdateLeaveForm" class="needs-validation" novalidate method="post">
                    <div class="modal-header">
                        <h4 class="modal-title">Update Leave Application</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="update_id" />
                        <div class="mb-3">
                            <label for="uEmployeeId" class="form-label">Employee <span class="text-danger">*</span></label>
                            <select id="uEmployeeId" data-choices class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="uLeaveCategoryId" class="form-label">Leave Category <span class="text-danger">*</span></label>
                            <select id="uLeaveCategoryId" data-choices class="form-select" required></select>
                        </div>
                        <div class="mb-3">
                            <label for="uStartDate" class="form-label">Start Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="uStartDate" required>
                        </div>
                        <div class="mb-3">
                            <label for="uEndDate" class="form-label">End Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="uEndDate" required>
                        </div>
                        <div class="mb-3">
                            <label for="uReason" class="form-label">Reason</label>
                            <textarea class="form-control" id="uReason" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="uStatus" class="form-label">Status <span class="text-danger">*</span></label>
                            <select id="uStatus" data-choices class="form-select" required>
                                <option value="Pending">Pending</option>
                                <option value="Approved">Approved</option>
                                <option value="Rejected">Rejected</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-soft-primary">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $.ajax({
            url: '/Staff/GetEmployeeList',
            type: 'GET',
            success: function (data) {
                var s = '<option value="" selected disabled>Select Employee</option>';
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].Id + '">' + data[i].FirstName + ' ' + data[i].LastName + '</option>';
                }
                $("#EmployeeId").html(s);
                $("#uEmployeeId").html(s);
            }
        });

        $.ajax({
            url: '/Leave/GetLeaveCategoriesList',
            type: 'GET',
            success: function (data) {
                var s = '<option value="" selected disabled>Select Leave Category</option>';
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].LeaveCategoryId + '">' + data[i].CategoryName + '</option>';
                }
                $("#LeaveCategoryId").html(s);
                $("#uLeaveCategoryId").html(s);
            }
        });

        $("#LeaveForm").on("submit", function (e) {
            e.preventDefault();
            if (!validateForm('LeaveForm')) {
                return false;
            }
            var formData = {
                EmployeeId: $("#EmployeeId").val(),
                LeaveCategoryId: $("#LeaveCategoryId").val(),
                StartDate: $("#StartDate").val(),
                EndDate: $("#EndDate").val(),
                Reason: $("#Reason").val(),
                Status: $("#Status").val()
            };
            $.ajax({
                url: '/Leave/SaveLeaveApplication',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });

        $("#UpdateLeaveForm").on("submit", function (e) {
            e.preventDefault();
            if (!validateForm('UpdateLeaveForm')) {
                return false;
            }
            var formData = {
                LeaveApplicationId: $("#update_id").val(),
                EmployeeId: $("#uEmployeeId").val(),
                LeaveCategoryId: $("#uLeaveCategoryId").val(),
                StartDate: $("#uStartDate").val(),
                EndDate: $("#uEndDate").val(),
                Reason: $("#uReason").val(),
                Status: $("#uStatus").val()
            };
            $.ajax({
                url: '/Leave/UpdateLeaveApplication',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        });
    });

    function UpdateLeave(id) {
        $.ajax({
            url: '/Leave/GetLeaveApplicationById',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                if (data) {
                    $("#update_id").val(data.LeaveApplicationId);
                    $("#uEmployeeId").val(data.EmployeeId);
                    $("#uLeaveCategoryId").val(data.LeaveCategoryId);
                    if (data.StartDate) {
                        var date = new Date(parseInt(data.StartDate.substr(6)));
                        var formattedDate = date.getFullYear() + '-' + ('0' + (date.getMonth() + 1)).slice(-2) + '-' + ('0' + date.getDate()).slice(-2);
                        $("#uStartDate").val(formattedDate);
                    }
                    if (data.EndDate) {
                        var date = new Date(parseInt(data.EndDate.substr(6)));
                        var formattedDate = date.getFullYear() + '-' + ('0' + (date.getMonth() + 1)).slice(-2) + '-' + ('0' + date.getDate()).slice(-2);
                        $("#uEndDate").val(formattedDate);
                    }
                    $("#uReason").val(data.Reason);
                    $("#uStatus").val(data.Status);
                    $("#UpdateLeaveModal").modal("show");
                }
            }
        });
    }

    function DeleteLeave(id) {
        if (confirm("Are you sure you want to delete this leave application?")) {
            $.ajax({
                url: '/Leave/DeleteLeaveApplication',
                type: "POST",
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                    }
                }
            });
        }
    }
</script>
